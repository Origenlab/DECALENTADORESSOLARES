---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const municipios = ["Benito Juárez", "Coyoacán", "Iztapalapa", "Gustavo A. Madero", "Álvaro Obregón", "Miguel Hidalgo", "Tlalpan", "Xochimilco", "Azcapotzalco", "Cuauhtémoc", "Iztacalco", "Venustiano Carranza", "Magdalena Contreras", "Milpa Alta", "Tláhuac", "Cuajimalpa"];

const faqItems = [
  { pregunta: '¿Instalan el mismo día que llaman?', respuesta: 'Según agenda, en la mayoría de los casos podemos instalar en 24-48 horas hábiles. Para urgencias intentamos el mismo día si hay disponibilidad.' },
  { pregunta: '¿Cubren todas las alcaldías de CDMX?', respuesta: 'Sí, las 16 alcaldías: Benito Juárez, Coyoacán, Iztapalapa, Tlalpan, Xochimilco y todas las demás sin costo adicional de traslado.' },
  { pregunta: '¿Funciona bien en invierno en CDMX?', respuesta: 'En invierno la CDMX tiene menos horas de sol efectivo pero los tubos evacuados al vacío captan radiación difusa. Se recomienda tener boiler de gas como respaldo para los 2-3 meses más fríos.' },
  { pregunta: '¿Tienen almacén en CDMX para entregas rápidas?', respuesta: 'Sí, contamos con stock disponible en CDMX para la mayoría de los modelos residenciales. No hay esperas de importación.' },
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Ciudad de México', description: 'Calentadores solares en CDMX: instalación profesional en 1 día, garantía 2 años. Servicio en las 16 alcaldías. Ahorra hasta 80% en gas. Cotización gratuita.', url: '/zonas/cdmx' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Zonas', url: '/zonas' },
    { name: 'Ciudad de México', url: '/zonas/cdmx' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares CDMX | Instalación el Mismo Día en Ciudad de México"
  description="Calentadores solares en CDMX: instalación profesional en 1 día, garantía 2 años. Servicio en las 16 alcaldías. Ahorra hasta 80% en gas. Cotización gratuita."
  activePage="zonas"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Zonas de servicio', url: '/zonas' },
    { name: 'Ciudad de México', url: '/zonas/cdmx' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares en Ciudad de México"
  heroIntro="Servicio completo de calentadores solares en las 16 alcaldías de la Ciudad de México. Instalación ese mismo día, técnicos certificados y garantía real de 2 años."
  heroBadge="Ciudad de México — Servicio disponible"
  heroMetrics={[
    { valor: '1 día', texto: 'Tiempo instalación' },
    { valor: '80%', texto: 'Ahorro en gas' },
    { valor: '2 años', texto: 'Garantía' },
    { valor: 'Gratis', texto: 'Cotización' },
  ]}
  heroPrimaryText="Cotización gratuita"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver tipos de calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Cobertura -->
  <section class="section section--alt" aria-labelledby="cobertura-title">
    <div class="container">
      <SectionHeader
        titulo="Municipios con servicio en Ciudad de México"
        subtitulo="Instalación en 24-72 horas hábiles en estas zonas"
        idTitulo="cobertura-title"
        parrafo1="La CDMX tiene entre 2,400 y 2,800 horas de sol al año — suficiente para que un calentador solar cubra el 75-85% de la demanda anual de agua caliente. El altiplano tiene excelente radiación solar difusa incluso en días nublados."
      />
      <div class="municipios-grid">
        {municipios.map((m: string) => (
          <div class="municipio-tag">{m}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué solar en Ciudad de México -->
  <section class="section" aria-labelledby="why-zona-title">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        titulo="¿Por qué instalar un calentador solar en Ciudad de México?"
        subtitulo="Recurso solar, clima y retorno de inversión en tu zona"
        idTitulo="why-zona-title"
      />
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-card__icon">☀️</div>
          <h3>Excelente recurso solar</h3>
          <p>Ciudad de México tiene entre 2,400 y 3,000 horas de sol anuales, suficiente para cubrir el 75-85% del consumo anual de agua caliente con energía solar.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">💰</div>
          <h3>Ahorro real desde el mes 1</h3>
          <p>Familias de 4 personas en Ciudad de México ahorran entre $700 y $1,200 pesos mensuales en gas. El sistema se paga solo en 2-3 años.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">🔧</div>
          <h3>Servicio técnico local</h3>
          <p>Contamos con técnicos certificados en Ciudad de México para instalación y mantenimiento. Tiempo de respuesta de 24-48 horas hábiles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" aria-labelledby="faq-zona-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes sobre Ciudad de México"
        subtitulo="Respuestas específicas para tu zona"
        idTitulo="faq-zona-title"
      />
      <div class="faq">
        {faqItems.map((item) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.municipios-grid {
  display: flex; flex-wrap: wrap; gap: var(--space-2);
  margin-top: var(--space-6);
}
.municipio-tag {
  background: var(--color-primary-50); color: var(--color-brand-dark);
  border: 1px solid var(--color-primary-100);
  font-size: var(--text-sm); font-weight: var(--weight-semibold);
  padding: var(--space-2) var(--space-4); border-radius: var(--radius-full);
}
.benefits-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-6); margin-top: var(--space-8);
}
.benefit-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-6);
  text-align: center;
}
.benefit-card__icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
.benefit-card h3 { font-size: var(--text-base); font-weight: var(--weight-bold); color: var(--color-dark); margin-bottom: var(--space-3); }
.benefit-card p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin: 0; }
</style>
