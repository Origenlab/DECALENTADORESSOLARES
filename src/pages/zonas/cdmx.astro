---
import LandingLayout from "../../layouts/LandingLayout.astro";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import Button from "../../components/ui/Button.astro";
import LeadCapture from "../../components/sections/LeadCapture.astro";

const alcaldias = [
  "Álvaro Obregón", "Azcapotzalco", "Benito Juárez", "Coyoacán",
  "Cuajimalpa", "Cuauhtémoc", "Gustavo A. Madero", "Iztacalco",
  "Iztapalapa", "La Magdalena Contreras", "Miguel Hidalgo", "Milpa Alta",
  "Tláhuac", "Tlalpan", "Venustiano Carranza", "Xochimilco"
];
---

<LandingLayout
  title="Instalación de Calentadores Solares en CDMX | Todas las Alcaldías"
  description="Instalamos calentadores solares en todas las alcaldías de la Ciudad de México. Técnicos certificados, servicio mismo día, garantía de mano de obra. Cotiza ahora."
>
  <Breadcrumb
    items={[
      { label: "Inicio", href: "/" },
      { label: "Zonas", href: "/zonas" },
      { label: "Ciudad de México" }
    ]}
  />

  <section class="hero-section">
    <div class="hero-layout">
      <div class="hero-panel">
        <span class="section-eyebrow">Cobertura completa</span>
        <h1 class="hero-title">Instalación de calentadores solares en Ciudad de México</h1>
        <p class="hero-lead">
          Atendemos las 16 alcaldías de la Ciudad de México con servicio profesional de instalación,
          mantenimiento y conversión de gas a solar. Técnicos certificados, respuesta en menos de
          24 horas y garantía de mano de obra en cada proyecto.
        </p>
        <div class="hero-cta-row">
          <Button
            href="https://wa.me/525500000000?text=Hola,%20quiero%20cotizar%20calentador%20solar%20en%20CDMX"
            target="_blank"
            rel="noopener noreferrer"
          >
            Cotizar en CDMX
          </Button>
          <Button href="/servicios/instalacion-profesional" variant="outline">Ver servicio de instalación</Button>
        </div>
      </div>

      <aside class="hero-aside">
        <h2>Servicios en CDMX</h2>
        <ul class="trust-list">
          <li>Instalación residencial y comercial.</li>
          <li>Mantenimiento preventivo anual.</li>
          <li>Conversión de gas a solar.</li>
          <li>Asesoría técnica sin costo.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section" aria-labelledby="alcaldias-title">
    <header class="section-header">
      <h2 id="alcaldias-title">Alcaldías con cobertura de servicio</h2>
      <p class="section-description">
        Instalamos calentadores solares en las 16 alcaldías de CDMX. Si tu colonia está en alguna
        de estas demarcaciones, te atendemos con técnico asignado en tu zona.
      </p>
    </header>

    <div class="coverage-grid">
      <article class="coverage-card">
        <h3>Cobertura inmediata</h3>
        <ul class="coverage-list">
          {alcaldias.slice(0, 8).map((a) => <li>{a}</li>)}
        </ul>
      </article>
      <article class="coverage-card">
        <h3>Toda la ciudad</h3>
        <ul class="coverage-list">
          {alcaldias.slice(8).map((a) => <li>{a}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="solar-cdmx-title">
    <header class="section-header">
      <h2 id="solar-cdmx-title">¿Por qué CDMX es ideal para calentadores solares?</h2>
    </header>

    <div class="offer-grid">
      <article class="offer-card">
        <h3>Alta irradiación solar</h3>
        <p>La Ciudad de México recibe en promedio 5.5 a 6.5 horas de sol pico diarias, suficiente para calentar agua incluso en temporada de lluvias.</p>
      </article>
      <article class="offer-card">
        <h3>Precio del gas en alza</h3>
        <p>El gas LP y natural en CDMX han incrementado su precio más del 40% en los últimos 5 años. El solar te protege de estas alzas.</p>
      </article>
      <article class="offer-card">
        <h3>Apoyos disponibles</h3>
        <p>Programas FIDE y SENER tienen subsidios activos para instalación de calentadores solares en hogares de CDMX que cumplen NOM-021-ENER-2017.</p>
      </article>
      <article class="offer-card">
        <h3>Densidad de azoteas</h3>
        <p>La gran mayoría de casas y edificios en CDMX tienen azotea disponible con orientación sur, la óptima para captar la mayor cantidad de energía solar.</p>
      </article>
    </div>
  </section>

  <LeadCapture source="zona-cdmx" />
</LandingLayout>
