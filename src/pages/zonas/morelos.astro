---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const municipios = ["Cuernavaca", "Jiutepec", "Cuautla", "Temixco", "Emiliano Zapata", "Xochitepec", "Yautepec", "Jojutla", "Puente de Ixtla", "Tepoztlán", "Tlaltizapán", "Ayala"];

const faqItems = [
  { pregunta: '¿En Morelos el calentador solar funciona todo el año?', respuesta: 'Sí. El clima templado y soleado de Morelos permite que el calentador solar funcione al 90-100% de eficiencia durante los 12 meses del año, sin necesidad de respaldo de gas en temporadas normales.' },
  { pregunta: '¿Cuánto se puede ahorrar en gas en Morelos?', respuesta: 'El ahorro puede llegar al 90-95% anual dado el excelente recurso solar. En la práctica, muchas familias eliminan casi por completo el consumo de gas para agua caliente.' },
  { pregunta: '¿Cuándo pueden instalar en Cuernavaca?', respuesta: 'Tenemos servicio regular en Cuernavaca y zona conurbada. El tiempo de respuesta es de 24-72 horas según agenda.' },
  { pregunta: '¿Es diferente el precio en Morelos que en CDMX?', respuesta: 'El precio del equipo es el mismo. Puede haber un costo de traslado adicional según la ubicación exacta, que se indica en la cotización.' },
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Morelos', description: 'Calentadores solares en Morelos: Cuernavaca, Jiutepec, Cuautla, Temixco y todo el estado. Clima ideal para máximo rendimiento solar. Instalación profesional.', url: '/zonas/morelos' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Zonas', url: '/zonas' },
    { name: 'Morelos', url: '/zonas/morelos' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Morelos | Cuernavaca, Jiutepec y Todo el Estado"
  description="Calentadores solares en Morelos: Cuernavaca, Jiutepec, Cuautla, Temixco y todo el estado. Clima ideal para máximo rendimiento solar. Instalación profesional."
  activePage="zonas"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Zonas de servicio', url: '/zonas' },
    { name: 'Morelos', url: '/zonas/morelos' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares en Morelos"
  heroIntro="Morelos tiene uno de los mejores climas de México para calentadores solares: templado, soleado y sin heladas. El sistema funciona al máximo rendimiento todo el año."
  heroBadge="Morelos — Servicio disponible"
  heroMetrics={[
    { valor: '1 día', texto: 'Tiempo instalación' },
    { valor: '80%', texto: 'Ahorro en gas' },
    { valor: '2 años', texto: 'Garantía' },
    { valor: 'Gratis', texto: 'Cotización' },
  ]}
  heroPrimaryText="Cotización gratuita"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver tipos de calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Cobertura -->
  <section class="section section--alt" aria-labelledby="cobertura-title">
    <div class="container">
      <SectionHeader
        titulo="Municipios con servicio en Morelos"
        subtitulo="Instalación en 24-72 horas hábiles en estas zonas"
        idTitulo="cobertura-title"
        parrafo1="Morelos tiene más de 3,000 horas de sol anuales y temperaturas templadas todo el año (promedio 22-26°C). Este clima es ideal para calentadores solares: el agua llega a temperaturas de 60-70°C sin esfuerzo incluso en diciembre."
      />
      <div class="municipios-grid">
        {municipios.map((m: string) => (
          <div class="municipio-tag">{m}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué solar en Morelos -->
  <section class="section" aria-labelledby="why-zona-title">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        titulo="¿Por qué instalar un calentador solar en Morelos?"
        subtitulo="Recurso solar, clima y retorno de inversión en tu zona"
        idTitulo="why-zona-title"
      />
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-card__icon">☀️</div>
          <h3>Excelente recurso solar</h3>
          <p>Morelos tiene entre 2,400 y 3,000 horas de sol anuales, suficiente para cubrir el 75-85% del consumo anual de agua caliente con energía solar.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">💰</div>
          <h3>Ahorro real desde el mes 1</h3>
          <p>Familias de 4 personas en Morelos ahorran entre $700 y $1,200 pesos mensuales en gas. El sistema se paga solo en 2-3 años.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">🔧</div>
          <h3>Servicio técnico local</h3>
          <p>Contamos con técnicos certificados en Morelos para instalación y mantenimiento. Tiempo de respuesta de 24-48 horas hábiles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" aria-labelledby="faq-zona-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes sobre Morelos"
        subtitulo="Respuestas específicas para tu zona"
        idTitulo="faq-zona-title"
      />
      <div class="faq">
        {faqItems.map((item) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.municipios-grid {
  display: flex; flex-wrap: wrap; gap: var(--space-2);
  margin-top: var(--space-6);
}
.municipio-tag {
  background: var(--color-primary-50); color: var(--color-brand-dark);
  border: 1px solid var(--color-primary-100);
  font-size: var(--text-sm); font-weight: var(--weight-semibold);
  padding: var(--space-2) var(--space-4); border-radius: var(--radius-full);
}
.benefits-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-6); margin-top: var(--space-8);
}
.benefit-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-6);
  text-align: center;
}
.benefit-card__icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
.benefit-card h3 { font-size: var(--text-base); font-weight: var(--weight-bold); color: var(--color-dark); margin-bottom: var(--space-3); }
.benefit-card p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin: 0; }
</style>
