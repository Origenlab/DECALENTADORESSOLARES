---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const municipios = ["Pachuca", "Tula de Allende", "Tulancingo", "Tepeji del Río", "Actopan", "Tizayuca", "Ixmiquilpan", "Apan", "Huejutla", "Zimapán", "Mineral del Monte", "Tepeapulco"];

const faqItems = [
  { pregunta: '¿Cubren Pachuca y zona metropolitana?', respuesta: 'Sí. Pachuca, Mineral de la Reforma, Zapotlán, Epazoyucan y municipios conurbados tienen servicio con tiempo de respuesta de 24-48 horas.' },
  { pregunta: '¿En Tizayuca, cerca de CDMX, hay servicio?', respuesta: 'Sí. Tizayuca y municipios del sur de Hidalgo son parte de la Zona Metropolitana y tienen el mismo tiempo de respuesta que CDMX.' },
  { pregunta: '¿Qué sistema conviene en la Huasteca hidalguense?', respuesta: 'En la zona cálida de Huejutla y la Huasteca, un sistema de paso solar sin tanque puede ser suficiente por el clima cálido todo el año. Consultamos en la asesoría.' },
  { pregunta: '¿El frío en Mineral del Monte afecta el rendimiento?', respuesta: 'Los tubos evacuados al vacío están diseñados para resistir temperaturas bajas. En Mineral del Monte (3,000 msnm) se recomienda sistema presurizado con anticongelante en el circuito.' },
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Hidalgo', description: 'Calentadores solares en Hidalgo: Pachuca, Tula, Tulancingo, Tepeji del Río y municipios del estado. Alta radiación solar en el altiplano hidalguense.', url: '/zonas/hidalgo' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Zonas', url: '/zonas' },
    { name: 'Hidalgo', url: '/zonas/hidalgo' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Hidalgo | Pachuca, Tula y Todo el Estado"
  description="Calentadores solares en Hidalgo: Pachuca, Tula, Tulancingo, Tepeji del Río y municipios del estado. Alta radiación solar en el altiplano hidalguense."
  activePage="zonas"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Zonas de servicio', url: '/zonas' },
    { name: 'Hidalgo', url: '/zonas/hidalgo' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares en Hidalgo"
  heroIntro="Hidalgo combina un excelente recurso solar con un clima variado. Desde el altiplano de Pachuca hasta los valles semitropicales de la Huasteca, tenemos el sistema correcto para cada zona."
  heroBadge="Hidalgo — Servicio disponible"
  heroMetrics={[
    { valor: '1 día', texto: 'Tiempo instalación' },
    { valor: '80%', texto: 'Ahorro en gas' },
    { valor: '2 años', texto: 'Garantía' },
    { valor: 'Gratis', texto: 'Cotización' },
  ]}
  heroPrimaryText="Cotización gratuita"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver tipos de calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Cobertura -->
  <section class="section section--alt" aria-labelledby="cobertura-title">
    <div class="container">
      <SectionHeader
        titulo="Municipios con servicio en Hidalgo"
        subtitulo="Instalación en 24-72 horas hábiles en estas zonas"
        idTitulo="cobertura-title"
        parrafo1="Hidalgo tiene recursos solares excelentes en su altiplano (Pachuca, Mineral del Monte, Apan) con más de 2,500 horas de sol anuales. La Huasteca hidalguense (Huejutla) tiene clima cálido con aún más radiación, ideal para sistemas de paso solar."
      />
      <div class="municipios-grid">
        {municipios.map((m: string) => (
          <div class="municipio-tag">{m}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué solar en Hidalgo -->
  <section class="section" aria-labelledby="why-zona-title">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        titulo="¿Por qué instalar un calentador solar en Hidalgo?"
        subtitulo="Recurso solar, clima y retorno de inversión en tu zona"
        idTitulo="why-zona-title"
      />
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-card__icon">☀️</div>
          <h3>Excelente recurso solar</h3>
          <p>Hidalgo tiene entre 2,400 y 3,000 horas de sol anuales, suficiente para cubrir el 75-85% del consumo anual de agua caliente con energía solar.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">💰</div>
          <h3>Ahorro real desde el mes 1</h3>
          <p>Familias de 4 personas en Hidalgo ahorran entre $700 y $1,200 pesos mensuales en gas. El sistema se paga solo en 2-3 años.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">🔧</div>
          <h3>Servicio técnico local</h3>
          <p>Contamos con técnicos certificados en Hidalgo para instalación y mantenimiento. Tiempo de respuesta de 24-48 horas hábiles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" aria-labelledby="faq-zona-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes sobre Hidalgo"
        subtitulo="Respuestas específicas para tu zona"
        idTitulo="faq-zona-title"
      />
      <div class="faq">
        {faqItems.map((item) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.municipios-grid {
  display: flex; flex-wrap: wrap; gap: var(--space-2);
  margin-top: var(--space-6);
}
.municipio-tag {
  background: var(--color-primary-50); color: var(--color-brand-dark);
  border: 1px solid var(--color-primary-100);
  font-size: var(--text-sm); font-weight: var(--weight-semibold);
  padding: var(--space-2) var(--space-4); border-radius: var(--radius-full);
}
.benefits-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-6); margin-top: var(--space-8);
}
.benefit-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-6);
  text-align: center;
}
.benefit-card__icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
.benefit-card h3 { font-size: var(--text-base); font-weight: var(--weight-bold); color: var(--color-dark); margin-bottom: var(--space-3); }
.benefit-card p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin: 0; }
</style>
