---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const municipios = ["Ciudad de Puebla", "Tehuacán", "San Martín Texmelucan", "Atlixco", "Cholula", "Amozoc", "Cuautlancingo", "Huejotzingo", "San Pedro Cholula", "Izúcar de Matamoros", "Acatzingo", "Tecamachalco"];

const faqItems = [
  { pregunta: '¿Instalan en el centro histórico de Puebla?', respuesta: 'Sí, incluyendo casas históricas con techo de teja. Hacemos la instalación con estructuras adaptadas al tipo de techo y respetando la estética del inmueble.' },
  { pregunta: '¿Qué tal funciona en invierno en Puebla?', respuesta: 'Puebla tiene inviernos fríos pero con buen sol. Los tubos evacuados funcionan bien incluso con temperaturas bajas. Se recomienda boiler de gas como respaldo para enero-febrero.' },
  { pregunta: '¿Cubren Tehuacán?', respuesta: 'Sí. Tehuacán y la zona de la Mixteca poblana tienen excelente sol. Consultamos disponibilidad de agenda para la zona.' },
  { pregunta: '¿El precio es el mismo que en CDMX?', respuesta: 'El equipo tiene el mismo precio. Puede haber un costo de traslado para municipios alejados de la capital poblana.' },
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Puebla', description: 'Calentadores solares en Puebla: Ciudad de Puebla, Tehuacán, San Martín Texmelucan, Atlixco y todo el estado. Instalación profesional, garantía incluida.', url: '/zonas/puebla' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Zonas', url: '/zonas' },
    { name: 'Puebla', url: '/zonas/puebla' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Puebla | Ciudad de Puebla y Todo el Estado"
  description="Calentadores solares en Puebla: Ciudad de Puebla, Tehuacán, San Martín Texmelucan, Atlixco y todo el estado. Instalación profesional, garantía incluida."
  activePage="zonas"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Zonas de servicio', url: '/zonas' },
    { name: 'Puebla', url: '/zonas/puebla' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares en Puebla"
  heroIntro="Instalación de calentadores solares en Ciudad de Puebla y principales municipios del estado. Excelente recurso solar en el altiplano poblano."
  heroBadge="Puebla — Servicio disponible"
  heroMetrics={[
    { valor: '1 día', texto: 'Tiempo instalación' },
    { valor: '80%', texto: 'Ahorro en gas' },
    { valor: '2 años', texto: 'Garantía' },
    { valor: 'Gratis', texto: 'Cotización' },
  ]}
  heroPrimaryText="Cotización gratuita"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver tipos de calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Cobertura -->
  <section class="section section--alt" aria-labelledby="cobertura-title">
    <div class="container">
      <SectionHeader
        titulo="Municipios con servicio en Puebla"
        subtitulo="Instalación en 24-72 horas hábiles en estas zonas"
        idTitulo="cobertura-title"
        parrafo1="Puebla tiene más de 2,600 horas de sol anuales. La ciudad capital y el altiplano tienen radiación solar muy similar a CDMX, con rendimientos excelentes en calentadores de tubos evacuados. Tehuacán, en zona más cálida, tiene aún más radiación."
      />
      <div class="municipios-grid">
        {municipios.map((m: string) => (
          <div class="municipio-tag">{m}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué solar en Puebla -->
  <section class="section" aria-labelledby="why-zona-title">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        titulo="¿Por qué instalar un calentador solar en Puebla?"
        subtitulo="Recurso solar, clima y retorno de inversión en tu zona"
        idTitulo="why-zona-title"
      />
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-card__icon">☀️</div>
          <h3>Excelente recurso solar</h3>
          <p>Puebla tiene entre 2,400 y 3,000 horas de sol anuales, suficiente para cubrir el 75-85% del consumo anual de agua caliente con energía solar.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">💰</div>
          <h3>Ahorro real desde el mes 1</h3>
          <p>Familias de 4 personas en Puebla ahorran entre $700 y $1,200 pesos mensuales en gas. El sistema se paga solo en 2-3 años.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">🔧</div>
          <h3>Servicio técnico local</h3>
          <p>Contamos con técnicos certificados en Puebla para instalación y mantenimiento. Tiempo de respuesta de 24-48 horas hábiles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" aria-labelledby="faq-zona-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes sobre Puebla"
        subtitulo="Respuestas específicas para tu zona"
        idTitulo="faq-zona-title"
      />
      <div class="faq">
        {faqItems.map((item) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.municipios-grid {
  display: flex; flex-wrap: wrap; gap: var(--space-2);
  margin-top: var(--space-6);
}
.municipio-tag {
  background: var(--color-primary-50); color: var(--color-brand-dark);
  border: 1px solid var(--color-primary-100);
  font-size: var(--text-sm); font-weight: var(--weight-semibold);
  padding: var(--space-2) var(--space-4); border-radius: var(--radius-full);
}
.benefits-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-6); margin-top: var(--space-8);
}
.benefit-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-6);
  text-align: center;
}
.benefit-card__icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
.benefit-card h3 { font-size: var(--text-base); font-weight: var(--weight-bold); color: var(--color-dark); margin-bottom: var(--space-3); }
.benefit-card p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin: 0; }
</style>
