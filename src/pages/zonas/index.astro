---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildLocalBusinessSchema, buildBreadcrumbSchema } from '../../lib/seo';
import { WHATSAPP_NUMBER, SITE_URL, SITE_NAME, GEO } from '../../lib/config';

const title = 'Zonas de Cobertura | Calentadores Solares en México';
const description = 'Instalamos calentadores solares en CDMX, Estado de México, Puebla, Morelos, Hidalgo, Querétaro y Tlaxcala. Cobertura profesional en centro de México.';

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Zonas', url: '/zonas' },
];

const zonas = [
  {
    nombre: 'Ciudad de México',
    slug: 'cdmx',
    desc: 'Cobertura en las 16 alcaldías. Servicio mismo día en Benito Juárez, Coyoacán, Miguel Hidalgo, Tlalpan y todas las demarcaciones.',
    municipios: '16 alcaldías',
  },
  {
    nombre: 'Estado de México',
    slug: 'estado-de-mexico',
    desc: 'Zona metropolitana y Valle de Toluca: Naucalpan, Tlalnepantla, Ecatepec, Huixquilucan, Metepec, Toluca y más.',
    municipios: '20+ municipios',
  },
  {
    nombre: 'Puebla',
    slug: 'puebla',
    desc: 'Puebla capital, Cholula, Atlixco, Tehuacán, San Martín Texmelucan, Huejotzingo y zona metropolitana.',
    municipios: '10+ municipios',
  },
  {
    nombre: 'Morelos',
    slug: 'morelos',
    desc: 'Cuernavaca, Jiutepec, Temixco, Cuautla y más. Uno de los mejores climas para energía solar en México.',
    municipios: '6+ municipios',
  },
  {
    nombre: 'Hidalgo',
    slug: 'hidalgo',
    desc: 'Pachuca, Tulancingo, Tizayuca, Mineral de la Reforma, Actopan y Tula de Allende.',
    municipios: '8+ municipios',
  },
  {
    nombre: 'Querétaro',
    slug: 'queretaro',
    desc: 'Santiago de Querétaro, San Juan del Río, Corregidora, El Marqués, Juriquilla y Tequisquiapan.',
    municipios: '6+ municipios',
  },
  {
    nombre: 'Tlaxcala',
    slug: null,
    desc: 'Tlaxcala capital, Apizaco, Huamantla y zonas aledañas. Consulta disponibilidad directamente por WhatsApp.',
    municipios: 'Consultar',
  },
];

const localBusiness = buildLocalBusinessSchema();
const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs);
---

<BaseLayout
  title={title}
  description={description}
  activePage="zonas"
  heroTitle="Zonas de Cobertura | Calentadores Solares en México"
  heroIntro="Instalamos en CDMX, Estado de México, Puebla, Morelos, Hidalgo, Querétaro y más."
  heroBadge="7 zonas de servicio"
  heroMetrics={[
    { valor: '7', texto: 'zonas' },
    { valor: '80+', texto: 'municipios' },
    { valor: '+500', texto: 'instalaciones' },
    { valor: '80%', texto: 'ahorro en gas' },
  ]}
  heroPrimaryText="Cotizar por WhatsApp"
  heroPrimaryLink={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('Hola, quiero cotizar un calentador solar. ¿Cubren mi zona?')}`}
  heroSecondaryText="Ver Productos"
  heroSecondaryLink="/productos"
  heroFeatures={[
    { icon: '📍', text: 'Cobertura en centro de México' },
    { icon: '🚀', text: 'Respuesta en 24h' },
    { icon: '🔧', text: 'Técnicos certificados' },
  ]}
  showLeadCapture={true}
  breadcrumbs={breadcrumbs}
  structuredData={[localBusiness, breadcrumbSchema]}
>

  <section class="section" aria-labelledby="zonas-title">
    <div class="container">
      <header class="section-header">
        <h2 id="zonas-title">Nuestras Zonas de Cobertura</h2>
        <p>Selecciona tu zona para conocer la cobertura detallada, municipios atendidos y tiempos de respuesta en tu área.</p>
      </header>

      <div class="grid-3">
        {zonas.map((zona) => (
          <div class="card">
            <div class="card__body">
              <span class="badge badge--primary">{zona.municipios}</span>
              <h3 class="card__title">{zona.nombre}</h3>
              <p class="card__desc">{zona.desc}</p>
              {zona.slug ? (
                <a href={`/zonas/${zona.slug}`} class="btn btn--primary">Ver cobertura</a>
              ) : (
                <a href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(`Hola, ¿cubren la zona de ${zona.nombre}?`)}`} class="btn btn--secondary" target="_blank" rel="noopener noreferrer">Consultar por WhatsApp</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt" aria-labelledby="no-zona-title">
    <div class="container">
      <header class="section-header">
        <h2 id="no-zona-title">¿No ves tu zona?</h2>
        <p>Estamos expandiendo nuestra cobertura constantemente. Contáctanos por WhatsApp y te confirmamos si podemos atenderte en tu ubicación.</p>
      </header>
      <div style="text-align:center;">
        <a href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('Hola, quiero saber si cubren mi zona para instalar un calentador solar.')}`} class="btn btn--primary" target="_blank" rel="noopener noreferrer">Preguntar por mi zona</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .card {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.08);
    background: var(--color-surface, #fff);
    transition: transform .2s, box-shadow .2s;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,.12);
  }
  .card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .badge {
    display: inline-block;
    font-size: .8rem;
    font-weight: 600;
    padding: .25rem .75rem;
    border-radius: 20px;
    width: fit-content;
  }
  .badge--primary {
    background: var(--color-primary-light, #FFF7ED);
    color: var(--color-primary, #F97316);
  }
</style>
