---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const municipios = ["Querétaro capital", "El Marqués", "Corregidora", "Huimilpan", "San Juan del Río", "Tequisquiapan", "Ezequiel Montes", "Amealco", "Cadereyta", "Jalpan de Serra", "Pedro Escobedo", "Colón"];

const faqItems = [
  { pregunta: '¿La zona industrial de Querétaro tiene servicio?', respuesta: 'Sí. Tanto la zona residencial como industrial (parques El Marqués, Bernardo Quintana) tienen cobertura. Para proyectos industriales ofrecemos estudio de factibilidad gratuito.' },
  { pregunta: '¿En Tequisquiapan y San Juan del Río hay servicio?', respuesta: 'Sí. La ruta Querétaro-San Juan del Río-Tequisquiapan tiene cobertura regular. El clima semiseco de esa zona es excelente para calentadores solares.' },
  { pregunta: '¿Qué tal funciona en diciembre-enero en Querétaro?', respuesta: 'Querétaro tiene inviernos secos y soleados, a diferencia de CDMX. Incluso en enero el rendimiento es bueno. Se recomienda respaldo de gas por las noches muy frías.' },
  { pregunta: '¿Instalan en la sierra queretana (Jalpan)?', respuesta: 'Para la Sierra Gorda consultamos disponibilidad. El clima subtropical de Jalpan es ideal para calentadores solares pero requiere coordinación logística especial.' },
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Querétaro', description: 'Calentadores solares en Querétaro: zona metropolitana, El Marqués, Corregidora, San Juan del Río y todo el estado. Excelente recurso solar. Instalación profesional.', url: '/zonas/queretaro' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Zonas', url: '/zonas' },
    { name: 'Querétaro', url: '/zonas/queretaro' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Querétaro | Instalación en Querétaro y Zona Metro"
  description="Calentadores solares en Querétaro: zona metropolitana, El Marqués, Corregidora, San Juan del Río y todo el estado. Excelente recurso solar. Instalación profesional."
  activePage="zonas"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Zonas de servicio', url: '/zonas' },
    { name: 'Querétaro', url: '/zonas/queretaro' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares en Querétaro"
  heroIntro="Querétaro es una de las zonas con mejor recurso solar del centro de México. Su cielo despejado la mayor parte del año hace que los calentadores solares sean extraordinariamente eficientes."
  heroBadge="Querétaro — Servicio disponible"
  heroMetrics={[
    { valor: '1 día', texto: 'Tiempo instalación' },
    { valor: '80%', texto: 'Ahorro en gas' },
    { valor: '2 años', texto: 'Garantía' },
    { valor: 'Gratis', texto: 'Cotización' },
  ]}
  heroPrimaryText="Cotización gratuita"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver tipos de calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Cobertura -->
  <section class="section section--alt" aria-labelledby="cobertura-title">
    <div class="container">
      <SectionHeader
        titulo="Municipios con servicio en Querétaro"
        subtitulo="Instalación en 24-72 horas hábiles en estas zonas"
        idTitulo="cobertura-title"
        parrafo1="Querétaro tiene más de 2,800 horas de sol anuales y clima seco la mayor parte del año. La temporada de lluvias (junio-septiembre) reduce el rendimiento temporalmente, pero el resto del año los calentadores solares funcionan al máximo."
      />
      <div class="municipios-grid">
        {municipios.map((m: string) => (
          <div class="municipio-tag">{m}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué solar en Querétaro -->
  <section class="section" aria-labelledby="why-zona-title">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        titulo="¿Por qué instalar un calentador solar en Querétaro?"
        subtitulo="Recurso solar, clima y retorno de inversión en tu zona"
        idTitulo="why-zona-title"
      />
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-card__icon">☀️</div>
          <h3>Excelente recurso solar</h3>
          <p>Querétaro tiene entre 2,400 y 3,000 horas de sol anuales, suficiente para cubrir el 75-85% del consumo anual de agua caliente con energía solar.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">💰</div>
          <h3>Ahorro real desde el mes 1</h3>
          <p>Familias de 4 personas en Querétaro ahorran entre $700 y $1,200 pesos mensuales en gas. El sistema se paga solo en 2-3 años.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">🔧</div>
          <h3>Servicio técnico local</h3>
          <p>Contamos con técnicos certificados en Querétaro para instalación y mantenimiento. Tiempo de respuesta de 24-48 horas hábiles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" aria-labelledby="faq-zona-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes sobre Querétaro"
        subtitulo="Respuestas específicas para tu zona"
        idTitulo="faq-zona-title"
      />
      <div class="faq">
        {faqItems.map((item) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.municipios-grid {
  display: flex; flex-wrap: wrap; gap: var(--space-2);
  margin-top: var(--space-6);
}
.municipio-tag {
  background: var(--color-primary-50); color: var(--color-brand-dark);
  border: 1px solid var(--color-primary-100);
  font-size: var(--text-sm); font-weight: var(--weight-semibold);
  padding: var(--space-2) var(--space-4); border-radius: var(--radius-full);
}
.benefits-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-6); margin-top: var(--space-8);
}
.benefit-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-6);
  text-align: center;
}
.benefit-card__icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
.benefit-card h3 { font-size: var(--text-base); font-weight: var(--weight-bold); color: var(--color-dark); margin-bottom: var(--space-3); }
.benefit-card p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin: 0; }
</style>
