---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const municipios = ["Ecatepec", "Naucalpan", "Tlalnepantla", "Toluca", "Nezahualcóyotl", "Chimalhuacán", "Atizapán de Zaragoza", "Cuautitlán Izcalli", "Huixquilucan", "Metepec", "Texcoco", "Tultitlán", "Ixtapaluca", "Valle de México"];

const faqItems = [
  { pregunta: '¿Cubren todo el Estado de México o solo municipios conurbados?', respuesta: 'Cubrimos toda la Zona Metropolitana del Valle de México sin costo extra. Para municipios más lejanos como Toluca, Valle de Bravo o Tejupilco consultamos disponibilidad y costos de traslado.' },
  { pregunta: '¿Instalan en Toluca?', respuesta: 'Sí. Toluca y municipios del Valle de Toluca tienen servicio regular. Por su altitud y clima, se recomienda calentador con tanque para retener el calor en las noches frías.' },
  { pregunta: '¿El precio es el mismo que en CDMX?', respuesta: 'Sí, el precio del equipo es el mismo. Puede haber un pequeño costo de traslado en municipios alejados de la zona conurbada.' },
  { pregunta: '¿Los municipios del norte como Cuautitlán tienen buen sol?', respuesta: 'Excelente. La zona norte del Edomex tiene clima más seco y despejado, ideal para calentadores solares con rendimiento mayor al promedio.' },
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Estado de México', description: 'Calentadores solares en el Estado de México: Ecatepec, Naucalpan, Tlalnepantla, Toluca, Nezahualcóyotl y más municipios. Instalación en 1 día. Cotización gratis.', url: '/zonas/estado-de-mexico' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Zonas', url: '/zonas' },
    { name: 'Estado de México', url: '/zonas/estado-de-mexico' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Estado de México | Instalación Profesional Edomex"
  description="Calentadores solares en el Estado de México: Ecatepec, Naucalpan, Tlalnepantla, Toluca, Nezahualcóyotl y más municipios. Instalación en 1 día. Cotización gratis."
  activePage="zonas"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Zonas de servicio', url: '/zonas' },
    { name: 'Estado de México', url: '/zonas/estado-de-mexico' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares en Estado de México"
  heroIntro="Instalación de calentadores solares en los principales municipios del Estado de México. Técnicos en zona, sin costos de traslado adicionales en municipios conurbados."
  heroBadge="Estado de México — Servicio disponible"
  heroMetrics={[
    { valor: '1 día', texto: 'Tiempo instalación' },
    { valor: '80%', texto: 'Ahorro en gas' },
    { valor: '2 años', texto: 'Garantía' },
    { valor: 'Gratis', texto: 'Cotización' },
  ]}
  heroPrimaryText="Cotización gratuita"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver tipos de calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Cobertura -->
  <section class="section section--alt" aria-labelledby="cobertura-title">
    <div class="container">
      <SectionHeader
        titulo="Municipios con servicio en Estado de México"
        subtitulo="Instalación en 24-72 horas hábiles en estas zonas"
        idTitulo="cobertura-title"
        parrafo1="El Estado de México comparte el excelente recurso solar del altiplano central. Los municipios conurbados con CDMX tienen radiación muy similar, y los municipios al norte (Teotihuacán, Jilotepec) tienen incluso más horas de sol por ser más secos."
      />
      <div class="municipios-grid">
        {municipios.map((m: string) => (
          <div class="municipio-tag">{m}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué solar en Estado de México -->
  <section class="section" aria-labelledby="why-zona-title">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        titulo="¿Por qué instalar un calentador solar en Estado de México?"
        subtitulo="Recurso solar, clima y retorno de inversión en tu zona"
        idTitulo="why-zona-title"
      />
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-card__icon">☀️</div>
          <h3>Excelente recurso solar</h3>
          <p>Estado de México tiene entre 2,400 y 3,000 horas de sol anuales, suficiente para cubrir el 75-85% del consumo anual de agua caliente con energía solar.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">💰</div>
          <h3>Ahorro real desde el mes 1</h3>
          <p>Familias de 4 personas en Estado de México ahorran entre $700 y $1,200 pesos mensuales en gas. El sistema se paga solo en 2-3 años.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card__icon">🔧</div>
          <h3>Servicio técnico local</h3>
          <p>Contamos con técnicos certificados en Estado de México para instalación y mantenimiento. Tiempo de respuesta de 24-48 horas hábiles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" aria-labelledby="faq-zona-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes sobre Estado de México"
        subtitulo="Respuestas específicas para tu zona"
        idTitulo="faq-zona-title"
      />
      <div class="faq">
        {faqItems.map((item) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.municipios-grid {
  display: flex; flex-wrap: wrap; gap: var(--space-2);
  margin-top: var(--space-6);
}
.municipio-tag {
  background: var(--color-primary-50); color: var(--color-brand-dark);
  border: 1px solid var(--color-primary-100);
  font-size: var(--text-sm); font-weight: var(--weight-semibold);
  padding: var(--space-2) var(--space-4); border-radius: var(--radius-full);
}
.benefits-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-6); margin-top: var(--space-8);
}
.benefit-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-6);
  text-align: center;
}
.benefit-card__icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
.benefit-card h3 { font-size: var(--text-base); font-weight: var(--weight-bold); color: var(--color-dark); margin-bottom: var(--space-3); }
.benefit-card p { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin: 0; }
</style>
