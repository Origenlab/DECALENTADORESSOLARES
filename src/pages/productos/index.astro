---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildBreadcrumbSchema, buildItemListSchema, buildCollectionPageSchema } from '../../lib/seo';

type Producto = CollectionEntry<'productos'>;
const allProducts = (await getCollection('productos') as Producto[])
  .sort((a, b) => (b.data.demandScore ?? 0) - (a.data.demandScore ?? 0));

const categorias = [
  { slug: 'residencial', label: 'Residencial', icon: '🏠', desc: 'Para casas y familias' },
  { slug: 'presurizado', label: 'Presurizado', icon: '💧', desc: 'Alta presión' },
  { slug: 'termosifon', label: 'Termosifón', icon: '♻️', desc: 'Sin bomba' },
  { slug: 'comercial', label: 'Comercial', icon: '🏨', desc: 'Negocios y hoteles' },
  { slug: 'industrial', label: 'Industrial', icon: '🏭', desc: 'Alta capacidad' },
];

const catCounts = allProducts.reduce((acc: Record<string, number>, p: Producto) => {
  acc[p.data.category] = (acc[p.data.category] || 0) + 1;
  return acc;
}, {});

const structuredData = [
  buildBreadcrumbSchema([{ name: 'Inicio', url: '/' }, { name: 'Productos', url: '/productos' }]),
  buildCollectionPageSchema('Catálogo de Calentadores Solares', 'Catálogo completo de calentadores solares en México: modelos residenciales, presurizados, comerciales e industriales.', '/productos'),
  buildItemListSchema('Calentadores Solares más vendidos', allProducts.slice(0, 10).map((p: Producto, i: number) => ({
    name: p.data.title,
    url: `/productos/${p.slug}`,
    image: p.data.image,
    position: i + 1,
  }))),
];
---

<BaseLayout
  title="Catálogo de Calentadores Solares | Precios y Modelos — De Calentadores Solares"
  description="Catálogo completo de calentadores solares en México: modelos de 10 a 30 tubos, residenciales, presurizados, comerciales. Precios desde $10,900 MXN instalados."
  activePage="productos"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Catálogo de productos', url: '/productos' }]}
  showHero={true}
  heroTitle="Catálogo de Calentadores Solares"
  heroIntro="Modelos residenciales, presurizados, comerciales e industriales. Encuentra el sistema correcto para tu consumo y presupuesto. Precios instalados sin sorpresas."
  heroBadge={`${allProducts.length} modelos disponibles`}
  heroMetrics={[
    { valor: `${allProducts.length}`, texto: 'Modelos' },
    { valor: '115-5000L', texto: 'Rango capacidad' },
    { valor: 'Desde $10,900', texto: 'Precio instalado' },
    { valor: 'Gratis', texto: 'Asesoría técnica' },
  ]}
  heroPrimaryText="Asesoría gratuita"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver tipos de sistemas"
  heroSecondaryLink="/calentadores"
>

  <!-- Filtros por categoría -->
  <section class="section section--alt" aria-label="Filtros de productos">
    <div class="container">
      <div class="cat-filters">
        <a href="/productos" class="cat-filter cat-filter--active">
          <span class="cat-filter__icon">🔆</span>
          <span class="cat-filter__label">Todos</span>
          <span class="cat-filter__count">{allProducts.length}</span>
        </a>
        {categorias.map(cat => (
          <a href={`/calentadores/${cat.slug}`} class="cat-filter">
            <span class="cat-filter__icon">{cat.icon}</span>
            <span class="cat-filter__label">{cat.label}</span>
            {catCounts[cat.slug] && <span class="cat-filter__count">{catCounts[cat.slug]}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Más vendidos -->
  <section class="section" aria-labelledby="top-title">
    <div class="container">
      <SectionHeader
        titulo="Modelos más vendidos"
        subtitulo="Los sistemas más elegidos por familias y negocios en México"
        idTitulo="top-title"
        enlaceTexto="Ver guía de selección"
        enlaceUrl="/calentadores"
      />
      <div class="grid-3">
        {allProducts.slice(0, 6).map((p: Producto, i: number) => (
          <ProductCard
            titulo={p.data.title}
            descripcion={p.data.description}
            enlace={`/productos/${p.slug}`}
            imagen={p.data.image?.startsWith('/img') ? p.data.image : '/img/categorias/calentador-solar-residencial-casa-cdmx.avif'}
            precio={p.data.price}
            precioMin={p.data.priceRangeMin}
            precioMax={p.data.priceRangeMax}
            capacidad={p.data.capacityLiters}
            tubos={p.data.tubeCount}
            usuarios={p.data.targetUsers}
            features={p.data.features}
            featured={i === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Por categoría -->
  {categorias.filter(c => catCounts[c.slug] > 0).map(cat => {
    const prods = allProducts.filter((p: Producto) => p.data.category === cat.slug);
    return prods.length > 0 ? (
      <section class="section section--alt" aria-labelledby={`cat-${cat.slug}-title`}>
        <div class="container">
          <SectionHeader
            titulo={`${cat.icon} Calentadores ${cat.label}`}
            subtitulo={cat.desc}
            idTitulo={`cat-${cat.slug}-title`}
            enlaceTexto={`Ver guía ${cat.label.toLowerCase()}`}
            enlaceUrl={`/calentadores/${cat.slug}`}
          />
          <div class="grid-3">
            {prods.map((p: Producto, i: number) => (
              <ProductCard
                titulo={p.data.title}
                descripcion={p.data.description}
                enlace={`/productos/${p.slug}`}
                imagen={p.data.image?.startsWith('/img') ? p.data.image : '/img/categorias/calentador-solar-residencial-casa-cdmx.avif'}
                precio={p.data.price}
                precioMin={p.data.priceRangeMin}
                precioMax={p.data.priceRangeMax}
                capacidad={p.data.capacityLiters}
                tubos={p.data.tubeCount}
                usuarios={p.data.targetUsers}
                features={p.data.features}
                featured={i === 0}
              />
            ))}
          </div>
        </div>
      </section>
    ) : null;
  })}

  <LeadCapture />

</BaseLayout>

<style>
.cat-filters {
  display: flex; flex-wrap: wrap; gap: var(--space-3);
  justify-content: center;
}
.cat-filter {
  display: flex; align-items: center; gap: var(--space-2);
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-full); padding: var(--space-2) var(--space-5);
  text-decoration: none; color: var(--color-text-secondary);
  font-size: var(--text-sm); font-weight: var(--weight-semibold);
  transition: border-color 0.2s, color 0.2s, background 0.2s;
}
.cat-filter:hover, .cat-filter--active {
  border-color: var(--color-brand); color: var(--color-brand);
  background: var(--color-primary-50);
}
.cat-filter__icon { font-size: 1.1rem; }
.cat-filter__count {
  background: var(--color-brand); color: #fff;
  font-size: var(--text-xs); font-weight: var(--weight-bold);
  padding: 0.1rem 0.4rem; border-radius: var(--radius-full);
  min-width: 1.4rem; text-align: center;
}
</style>
