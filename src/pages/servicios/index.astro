---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const faqItems = [
  { pregunta: '¿Cuánto tarda la instalación de un calentador solar?', respuesta: 'La instalación residencial estándar dura entre 3 y 5 horas el mismo día. Instalaciones comerciales de mayor escala pueden requerir 1-2 días.' },
  { pregunta: '¿Ofrecen garantía en la instalación?', respuesta: 'Sí. Garantizamos la mano de obra por 1 año y los equipos conforme a la garantía del fabricante (2-5 años según modelo). Si algo falla por instalación, vamos sin costo.' },
  { pregunta: '¿Realizan visita técnica previa?', respuesta: 'Para proyectos comerciales siempre realizamos visita previa gratuita. Para proyectos residenciales hacemos el diagnóstico con fotos que nos envías por WhatsApp.' },
  { pregunta: '¿En qué zonas tienen servicio de mantenimiento?', respuesta: 'Damos mantenimiento en CDMX, Estado de México, Morelos, Hidalgo, Puebla, Querétaro y Tlaxcala. Para otras zonas coordinamos según volumen.' },
];

const structuredData = [
  buildServiceSchema({ name: 'Instalación de calentadores solares', description: 'Instalación profesional de sistemas solares térmicos residenciales y comerciales en México.', url: '/servicios/instalacion-profesional' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([{ name: 'Inicio', url: '/' }, { name: 'Servicios', url: '/servicios' }]),
];
---

<BaseLayout
  title="Servicios de Calentadores Solares | Instalación y Mantenimiento"
  description="Instalación, mantenimiento y asesoría técnica de calentadores solares en CDMX y México. Servicio llave en mano con garantía. Proyectos residenciales y comerciales."
  activePage="servicios"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Servicios', url: '/servicios' }]}
  showHero={true}
  heroTitle="Servicios de Instalación y Mantenimiento Solar"
  heroIntro="Instalamos, mantenemos y asesoramos proyectos solares en CDMX y toda la República. Cada servicio con garantía real y técnicos certificados."
  heroBadge="Técnicos certificados"
  heroMetrics={[
    { valor: '+500', texto: 'Instalaciones' },
    { valor: '1 día', texto: 'Instalación residencial' },
    { valor: '100%', texto: 'Garantía' },
  ]}
  heroPrimaryText="Solicitar Servicio"
  heroPrimaryLink="#cotizar"
  heroSecondaryText="Ver Calentadores"
  heroSecondaryLink="/productos"
>

  <section class="section" aria-labelledby="services-title">
    <div class="container">
      <SectionHeader
        titulo="Nuestros Servicios"
        subtitulo="Soluciones completas para que tengas agua caliente solar sin preocupaciones"
        idTitulo="services-title"
        parrafo1="Desde la asesoría técnica inicial hasta el mantenimiento preventivo años después, acompañamos cada proyecto de principio a fin. No solo vendemos el equipo: garantizamos que funcione."
        parrafo2="Trabajamos con instaladores certificados, materiales de primera calidad y un protocolo de instalación que incluye prueba de presión y puesta en marcha antes de salir."
      />
      <div class="grid-3" style="gap: var(--space-8);">
        <ServiceCard
          titulo="Instalación profesional"
          descripcion="Proyecto llave en mano: diagnóstico, montaje de soporte, instalación de equipo, conexión hidráulica, prueba de presión y puesta en marcha el mismo día."
          enlace="/servicios/instalacion-profesional"
          icono="🔧"
          beneficios={['Instalación en 1 día', 'Prueba de presión incluida', 'Garantía de mano de obra 1 año', 'Asesoría de uso y mantenimiento']}
        />
        <ServiceCard
          titulo="Mantenimiento preventivo"
          descripcion="Plan periódico de revisión para sostener la eficiencia térmica y garantizar los 15-20 años de vida útil del sistema solar."
          enlace="/servicios/mantenimiento-preventivo"
          icono="🛡️"
          beneficios={['Revisión de tubos evacuados', 'Cambio de ánodo de magnesio', 'Limpieza interna del tanque', 'Informe técnico escrito']}
        />
        <ServiceCard
          titulo="Asesoría técnica"
          descripcion="Dimensionamiento correcto según tu consumo real, tipo de inmueble y red hidráulica. Sin costo y sin compromiso de compra."
          enlace="/servicios/asesoria-tecnica"
          icono="📋"
          beneficios={['Cálculo de capacidad exacta', 'Comparativa de modelos', 'Análisis de ROI personalizado', 'Visita técnica gratuita']}
        />
        <ServiceCard
          titulo="Proyectos comerciales"
          descripcion="Diseño e instalación de sistemas solares de alta capacidad para hoteles, gimnasios, restaurantes, plantas industriales y edificios."
          enlace="/servicios/proyectos-comerciales"
          icono="🏗️"
          beneficios={['Estudio de factibilidad', 'Diseño a medida', 'Coordinación con obra civil', 'Soporte post-instalación']}
        />
        <ServiceCard
          titulo="Mantenimiento correctivo"
          descripcion="Diagnóstico y reparación de sistemas solares con bajo rendimiento, fugas, tubos rotos o componentes fallados."
          enlace="/servicios/mantenimiento-preventivo"
          icono="🔍"
          beneficios={['Diagnóstico el mismo día', 'Reposición de tubos en sitio', 'Sellado de fugas y conexiones', 'Garantía de reparación']}
        />
        <ServiceCard
          titulo="Conversión de sistema"
          descripcion="Migración de calentador de gas a solar, o actualización de sistema solar obsoleto a tecnología de tubos evacuados de alta eficiencia."
          enlace="/servicios/conversion"
          icono="♻️"
          beneficios={['Aprovecha instalación existente', 'Mínima modificación hidráulica', 'Retiro del equipo anterior', 'Asesoría de financiamiento']}
        />
      </div>
    </div>
  </section>

  <LeadCapture />

  <section class="section section--alt" aria-labelledby="faq-servicios">
    <div class="container" style="max-width: 760px;">
      <SectionHeader titulo="Preguntas sobre nuestros servicios" subtitulo="Resolvemos las dudas más comunes" idTitulo="faq-servicios" />
      <div class="faq">
        {faqItems.map((item, i) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
