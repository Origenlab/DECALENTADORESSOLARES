---
import LandingLayout from "../../layouts/LandingLayout.astro";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import Button from "../../components/ui/Button.astro";
import LeadCapture from "../../components/sections/LeadCapture.astro";
---

<LandingLayout
  title="Instalación de Calentadores Solares en CDMX y Edomex | Profesional y Certificada"
  description="Instalación profesional de calentadores solares en CDMX, Estado de México y zona metropolitana. Técnicos certificados, puesta en marcha y garantía de mano de obra."
>
  <Breadcrumb
    items={[
      { label: "Inicio", href: "/" },
      { label: "Servicios", href: "/servicios" },
      { label: "Instalación" }
    ]}
  />

  <section class="hero-section">
    <div class="hero-layout">
      <div class="hero-panel">
        <span class="section-eyebrow">Servicio en CDMX y Edomex</span>
        <h1 class="hero-title">Instalación de calentadores solares en CDMX y Estado de México</h1>
        <p class="hero-lead">
          Equipo de técnicos certificados que realiza el proyecto completo: levantamiento técnico,
          montaje, conexiones, pruebas y puesta en marcha. Atendemos toda la Ciudad de México,
          Estado de México y zona metropolitana.
        </p>
        <div class="hero-cta-row">
          <Button
            href="https://wa.me/525500000000?text=Hola,%20quiero%20agendar%20instalacion%20de%20calentador%20solar%20en%20CDMX"
            target="_blank"
            rel="noopener noreferrer"
          >
            Agendar instalación
          </Button>
          <Button href="/zonas/cdmx" variant="outline">Zonas de cobertura CDMX</Button>
        </div>
      </div>

      <aside class="hero-aside">
        <h2>Zonas de atención</h2>
        <ul class="trust-list">
          <li>Ciudad de México — todas las alcaldías.</li>
          <li>Naucalpan, Tlalnepantla, Ecatepec.</li>
          <li>Toluca y zona metropolitana.</li>
          <li>Puebla y área metropolitana.</li>
          <li>Querétaro, Hidalgo, Morelos.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section" aria-labelledby="alcance-instalacion-title">
    <header class="section-header">
      <h2 id="alcance-instalacion-title">¿Qué incluye el servicio de instalación?</h2>
    </header>

    <div class="offer-grid">
      <article class="offer-card">
        <h3>Levantamiento técnico</h3>
        <p>Evaluación de azotea, orientación solar, estructura, presión de agua y consumo estimado antes de iniciar la instalación.</p>
      </article>
      <article class="offer-card">
        <h3>Montaje y estructuras</h3>
        <p>Instalación de la estructura soporte, colectores solares y tanque de almacenamiento con anclajes seguros.</p>
      </article>
      <article class="offer-card">
        <h3>Conexiones hidráulicas</h3>
        <p>Integración al sistema de agua existente con válvulas, by-pass de gas y todas las conexiones necesarias.</p>
      </article>
      <article class="offer-card">
        <h3>Pruebas y puesta en marcha</h3>
        <p>Pruebas de presión, hermeticidad y temperatura. Verificación de funcionamiento correcto antes de entregar.</p>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="normativa-instalacion-title">
    <header class="section-header">
      <h2 id="normativa-instalacion-title">Instalación conforme a normativa NOM-021-ENER-2017</h2>
      <p class="section-description">
        Todos nuestros proyectos cumplen con la Norma Oficial Mexicana NOM-021-ENER-2017 para
        calentadores solares de agua. Esto garantiza eficiencia energética real y compatibilidad
        con programas de apoyo FIDE y SENER.
      </p>
    </header>

    <div class="comparison-grid">
      <article class="comparison-card comparison-card--good">
        <h3>Cumplimiento normativo</h3>
        <ul class="features-list">
          <li>NOM-021-ENER-2017 aplicada en cada proyecto.</li>
          <li>Equipos de marcas certificadas: Solaris, Rotoplás Solar, Solarmat, Tecnosol.</li>
          <li>Documentación técnica de cada instalación.</li>
          <li>Elegible para subsidios FIDE y SENER.</li>
        </ul>
      </article>
      <article class="comparison-card comparison-card--good">
        <h3>Tiempo de instalación</h3>
        <ul class="features-list">
          <li>Residencial: 1 día hábil.</li>
          <li>Comercial pequeño (hasta 3 colectores): 1 a 2 días.</li>
          <li>Comercial grande: 3 a 5 días según alcance.</li>
          <li>Industrial: fases según diseño.</li>
        </ul>
      </article>
    </div>
  </section>

  <LeadCapture source="servicio-instalacion-cdmx" />
</LandingLayout>
