---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const pasos: [string, string][] = [["1. Evaluación del sistema actual", "Revisamos tu instalación de gas, el boiler existente y el espacio en techo para determinar la mejor configuración."], ["2. Diseño del sistema híbrido", "Diseñamos la integración solar más gas: el solar es la fuente principal y el boiler activa automáticamente solo cuando es necesario."], ["3. Instalación del colector solar", "Montamos el calentador solar en el techo y conectamos al sistema hidráulico existente. El boiler de gas queda como respaldo automático."], ["4. Configuración del respaldo", "Ajustamos la temperatura de activación del boiler de gas para que solo encienda cuando el solar no alcanza la temperatura deseada."], ["5. Prueba y entrega", "Verificamos el correcto funcionamiento de ambos sistemas, medimos temperaturas y entregamos manual de uso."]];

const faqItems = [
  { pregunta: '¿Mi boiler de gas queda inutilizable?', respuesta: 'No. Queda funcionando como respaldo automático. En días sin sol o en invierno intenso, el gas activa solo cuando el agua solar no alcanza la temperatura programada.' },
  { pregunta: '¿Cuánto ahorro real espero?', respuesta: 'En CDMX el sistema solar cubre el 75-85% del año. Solo en los 2-3 meses más fríos el gas trabaja activamente. El ahorro anual promedio es del 70-75%.' },
  { pregunta: '¿Se puede hacer en departamento?', respuesta: 'Si el departamento tiene acceso a azotea compartida o propia, sí es posible. Requiere permiso de la administración del edificio.' },
  { pregunta: '¿Necesito cambiar las tuberías de mi casa?', respuesta: 'Generalmente no. El sistema solar se conecta a la red hidráulica existente. Solo se agregan las tuberías de la azotea al boiler.' },
  { pregunta: '¿Qué pasa si se acaba el gas?', respuesta: 'El sistema solar sigue funcionando independientemente del gas. En días soleados tendrás agua caliente aunque no haya gas.' },
];

const structuredData = [
  buildServiceSchema({ name: 'Conversión de Calentador de Gas a Sistema Solar', description: 'Convierte tu calentador de gas a un sistema solar en CDMX. Mantén tu boiler de gas como respaldo y ahorra hasta 80% en tu factura mensual. Instalación profesional.', url: '/servicios/conversion' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Servicios', url: '/servicios' },
    { name: 'Conversión de Calentador de Gas a Sistema Solar', url: '/servicios/conversion' },
  ]),
];
---

<BaseLayout
  title="Conversión de Calentador de Gas a Solar | Ahorra 80% desde Hoy"
  description="Convierte tu calentador de gas a un sistema solar en CDMX. Mantén tu boiler de gas como respaldo y ahorra hasta 80% en tu factura mensual. Instalación profesional."
  activePage="servicios"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Servicios', url: '/servicios' },
    { name: 'Conversión de Calentador de Gas a Sistema Solar', url: '/servicios/conversion' },
  ]}
  showHero={true}
  heroTitle="Conversión de Calentador de Gas a Sistema Solar"
  heroIntro="Instalamos un calentador solar como sistema principal y tu boiler queda como respaldo para días muy nublados. Ahorra hasta 80% en gas sin sacrificar comodidad."
  heroBadge="Conversión en 1 día"
  heroMetrics={[{ valor: '80%', texto: 'Reducción en gas' }, { valor: '1 día', texto: 'Tiempo de conversión' }, { valor: '2-3 años', texto: 'ROI' }, { valor: 'Gas', texto: 'Queda como respaldo' }]}
  heroPrimaryText="Solicitar este servicio"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver todos los servicios"
  heroSecondaryLink="/servicios"
>

  <section class="section section--alt" aria-labelledby="proceso-title">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        titulo="¿Cómo funciona el proceso?"
        subtitulo="Transparencia total desde el primer contacto"
        idTitulo="proceso-title"
      />
      <div class="steps">
        {pasos.map(([titulo, desc]) => (
          <div class="step">
            <div class="step__title">{titulo}</div>
            <div class="step__desc">{desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="faq-serv-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes"
        subtitulo="Todo lo que necesitas saber antes de contratar"
        idTitulo="faq-serv-title"
      />
      <div class="faq">
        {faqItems.map((item) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.steps { display: flex; flex-direction: column; gap: var(--space-4); margin-top: var(--space-6); }
.step {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-left: 4px solid var(--color-brand); border-radius: var(--radius-lg);
  padding: var(--space-5) var(--space-6);
}
.step__title { font-size: var(--text-base); font-weight: var(--weight-bold); color: var(--color-dark); margin-bottom: var(--space-2); }
.step__desc { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); }
</style>
