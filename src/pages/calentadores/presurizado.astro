---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const allProducts = await getCollection('productos');
const products = allProducts.filter((p: CollectionEntry<'productos'>) => p.data.category === 'presurizado');

const faqItems = [
  { pregunta: "¿En qué se diferencia el presurizado del termosifón?", respuesta: "El termosifón usa convección natural (sin bomba), es más económico pero requiere el tanque elevado. El presurizado usa bomba eléctrica de bajo consumo (~50W) y puede instalar el tanque donde sea necesario." },
  { pregunta: "¿Cuánta electricidad consume la bomba?", respuesta: "La bomba circuladora consume aproximadamente 50-80W y solo opera cuando hay diferencia de temperatura entre el colector y el tanque. El consumo mensual adicional es de $40-$80 pesos, insignificante frente al ahorro en gas." },
  { pregunta: "¿Es compatible con mi sistema hidro-neumático?", respuesta: "Sí. El sistema presurizado entrega agua a la misma presión que tu red existente. Es totalmente compatible con hidro-neumático y no requiere modificar el sistema de presión del inmueble." },
  { pregunta: "¿Puede instalarse en edificio de departamentos?", respuesta: "Sí, es la mejor opción para edificios porque el tanque puede ir en el cuarto de máquinas o un local técnico, sin ocupar espacio visual en el techo de forma permanente." },
  { pregunta: "¿Qué pasa si se va la luz?", respuesta: "En caso de corte eléctrico, el sistema deja de circular activamente pero el agua caliente almacenada en el tanque permanece disponible. Al regresar la luz el sistema retoma operación automáticamente." }
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Presurizados', description: 'Sistemas de calentamiento solar presurizado para redes de alta demanda en México. Mayor flujo, mejor rendimiento y compatible con hidro-neumático. Instalación profesional.', url: '/calentadores/presurizado' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares Presurizados', url: '/calentadores/presurizado' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Presurizados | Alta Presión y Máximo Rendimiento"
  description="Sistemas de calentamiento solar presurizado para redes de alta demanda en México. Mayor flujo, mejor rendimiento y compatible con hidro-neumático. Instalación profesional."
  activePage="calentadores"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares Presurizados', url: '/calentadores/presurizado' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares Presurizados"
  heroIntro="Mayor rendimiento, flujo constante y compatibilidad con cualquier red hidráulica. El sistema ideal para casas con hidro-neumático, edificios y proyectos exigentes."
  heroBadge="Tecnología premium"
  heroMetrics={[
        { valor: "150-500L", texto: "Capacidad" },
    { valor: "85%", texto: "Eficiencia" },
    { valor: "Alta presión", texto: "Compatible" },
    { valor: "20 años", texto: "Vida útil" }
  ]}
  heroPrimaryText="Cotizar este sistema"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver todos los calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Por qué elegir este sistema -->
  <section class="section section--alt" aria-labelledby="why-title">
    <div class="container">
      <SectionHeader
        titulo="¿Por qué elegir Calentadores Solares Presurizados?"
        subtitulo="Ventajas técnicas y económicas que hacen la diferencia"
        idTitulo="why-title"
        parrafo1="El sistema presurizado usa una bomba de circulación y controlador electrónico para mover el agua entre los colectores y el tanque. A diferencia del termosifón —que depende de la convección natural— el presurizado funciona con el tanque en cualquier posición y a cualquier altura."
        parrafo2="Esta flexibilidad lo hace ideal para casas de varios pisos, edificios de departamentos, inmuebles con sistema hidro-neumático o cualquier proyecto donde no se pueda instalar el tanque por encima de los colectores."
      />
    </div>
  </section>

  <!-- Productos del catálogo -->
  {products.length > 0 && (
    <section class="section" aria-labelledby="products-title">
      <div class="container">
        <SectionHeader
          titulo="Modelos disponibles"
          subtitulo="Selecciona el que mejor se adapta a tu consumo y presupuesto"
          enlaceTexto="Ver catálogo completo"
          enlaceUrl="/productos"
          idTitulo="products-title"
        />
        <div class="grid-3 products-grid">
          {products.map((p: CollectionEntry<'productos'>, i: number) => (
            <ProductCard
              titulo={p.data.title}
              descripcion={p.data.description}
              enlace={`/productos/${p.slug}`}
              imagen={p.data.image.startsWith('/img') ? p.data.image : '/img/categorias/calentador-solar-residencial-casa-cdmx.avif'}
              precio={p.data.price}
              precioMin={p.data.priceRangeMin}
              precioMax={p.data.priceRangeMax}
              capacidad={p.data.capacityLiters}
              tubos={p.data.tubeCount}
              usuarios={p.data.targetUsers}
              features={p.data.features}
              featured={i === 0}
            />
          ))}
        </div>
        {products.length === 0 && (
          <div class="no-products">
            <p>Contáctanos para conocer los modelos disponibles para este tipo de sistema.</p>
            <a href="/cotizar" class="btn btn--primary">Solicitar cotización →</a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Tabla comparativa -->
  <section class="section section--alt" aria-labelledby="comp-title">
    <div class="container" style="max-width: 900px;">
      <SectionHeader
        titulo="Comparativa de modelos"
        subtitulo="Elige el tamaño correcto para tu consumo"
        idTitulo="comp-title"
      />
      <div class="comp-table-wrap">
        <table class="comp-table" aria-label="Comparativa de modelos">
          <thead>
            <tr>
              <th>Sistema</th><th>Circulación</th><th>Instalación</th><th>Uso recomendado</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Termosifón</td><td>Convección natural</td><td>Tanque debe estar arriba</td><td>Residencial estándar</td></tr>
            <tr><td>Presurizado</td><td>Bomba + controlador</td><td>Tanque en cualquier posición</td><td>Residencial premium / comercial</td></tr>
            <tr><td>Sistema doble</td><td>2 circuitos</td><td>Máxima capacidad</td><td>Industrial / hotel grande</td></tr>
            
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes"
        subtitulo="Todo lo que necesitas saber sobre calentadores solares presurizados"
        idTitulo="faq-title"
      />
      <div class="faq">
        {faqItems.map((item, i) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.products-grid { margin-top: var(--space-4); }
.no-products {
  text-align: center; padding: var(--space-12);
  background: var(--color-bg-alt); border-radius: var(--radius-xl);
  display: flex; flex-direction: column; align-items: center; gap: var(--space-4);
}
.comp-table-wrap { overflow-x: auto; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.comp-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
.comp-table th {
  background: var(--color-dark); color: #fff;
  padding: var(--space-4) var(--space-5); text-align: left;
  font-weight: var(--weight-semibold); white-space: nowrap;
}
.comp-table td {
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text-secondary);
}
.comp-table tr:last-child td { border-bottom: none; }
.comp-table tr:nth-child(even) td { background: var(--color-bg-alt); }
</style>
