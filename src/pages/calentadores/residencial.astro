---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const allProducts = await getCollection('productos');
const products = allProducts.filter((p: CollectionEntry<'productos'>) => p.data.category === 'residencial');

const faqItems = [
  { pregunta: "¿Cuántos litros necesito para mi familia?", respuesta: "La regla general es 50 litros por persona al día. Para 4 personas: 200 litros mínimo. Si tienen ducha de alta presión o bañera, suma un 20% adicional." },
  { pregunta: "¿Cuánto tiempo tarda la instalación?", respuesta: "La instalación residencial estándar dura 3-5 horas el mismo día. Incluye montaje, conexión hidráulica, prueba de presión y explicación de uso." },
  { pregunta: "¿Funciona en días nublados?", respuesta: "Sí. Los tubos evacuados absorben radiación difusa. En días parcialmente nublados rinden al 60-80%. Solo con lluvia intensa bajan al 15-30%, y el tanque aislado conserva el agua caliente del día anterior." },
  { pregunta: "¿Cuánto ahorro en gas?", respuesta: "En promedio del 70-80% anual. Un hogar de 4 personas que gastaba $1,200/mes en gas para agua caliente pasa a gastar $200-$300 con respaldo solar." },
  { pregunta: "¿Qué mantenimiento necesita?", respuesta: "Mínimo: revisión anual del ánodo de magnesio, limpieza del tanque cada 3-5 años. Nosotros ofrecemos planes de mantenimiento preventivo con garantía." }
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Residenciales', description: 'Calentadores solares residenciales de 115 a 300 litros para casas en CDMX y México. Ahorra hasta 80% en gas. Instalación profesional en 1 día. Garantía incluida.', url: '/calentadores/residencial' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares Residenciales', url: '/calentadores/residencial' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Residenciales | Para Casas y Familias en México"
  description="Calentadores solares residenciales de 115 a 300 litros para casas en CDMX y México. Ahorra hasta 80% en gas. Instalación profesional en 1 día. Garantía incluida."
  activePage="calentadores"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares Residenciales', url: '/calentadores/residencial' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares Residenciales"
  heroIntro="Sistemas de tubos evacuados al vacío para familias de 2 a 8 personas. Ahorro real de 60-80% en gas desde el primer mes. Instalación ese mismo día."
  heroBadge="Más vendido en México"
  heroMetrics={[
        { valor: "115-300L", texto: "Capacidad" },
    { valor: "80%", texto: "Ahorro gas" },
    { valor: "1 día", texto: "Instalación" },
    { valor: "15-20 años", texto: "Vida útil" }
  ]}
  heroPrimaryText="Cotizar este sistema"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver todos los calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Por qué elegir este sistema -->
  <section class="section section--alt" aria-labelledby="why-title">
    <div class="container">
      <SectionHeader
        titulo="¿Por qué elegir Calentadores Solares Residenciales?"
        subtitulo="Ventajas técnicas y económicas que hacen la diferencia"
        idTitulo="why-title"
        parrafo1="El calentador solar residencial es la mejor inversión que puede hacer un hogar mexicano. La energía solar es gratuita, abundante en México y suficiente para cubrir entre el 75% y el 85% del consumo anual de agua caliente."
        parrafo2="Nuestros sistemas utilizan tecnología de tubos evacuados al vacío —la más eficiente del mercado— que funciona incluso en días nublados, a diferencia de los colectores de placa plana que solo aprovechan la radiación directa."
      />
    </div>
  </section>

  <!-- Productos del catálogo -->
  {products.length > 0 && (
    <section class="section" aria-labelledby="products-title">
      <div class="container">
        <SectionHeader
          titulo="Modelos disponibles"
          subtitulo="Selecciona el que mejor se adapta a tu consumo y presupuesto"
          enlaceTexto="Ver catálogo completo"
          enlaceUrl="/productos"
          idTitulo="products-title"
        />
        <div class="grid-3 products-grid">
          {products.map((p: CollectionEntry<'productos'>, i: number) => (
            <ProductCard
              titulo={p.data.title}
              descripcion={p.data.description}
              enlace={`/productos/${p.slug}`}
              imagen={p.data.image.startsWith('/img') ? p.data.image : '/img/categorias/calentador-solar-residencial-casa-cdmx.avif'}
              precio={p.data.price}
              precioMin={p.data.priceRangeMin}
              precioMax={p.data.priceRangeMax}
              capacidad={p.data.capacityLiters}
              tubos={p.data.tubeCount}
              usuarios={p.data.targetUsers}
              features={p.data.features}
              featured={i === 0}
            />
          ))}
        </div>
        {products.length === 0 && (
          <div class="no-products">
            <p>Contáctanos para conocer los modelos disponibles para este tipo de sistema.</p>
            <a href="/cotizar" class="btn btn--primary">Solicitar cotización →</a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Tabla comparativa -->
  <section class="section section--alt" aria-labelledby="comp-title">
    <div class="container" style="max-width: 900px;">
      <SectionHeader
        titulo="Comparativa de modelos"
        subtitulo="Elige el tamaño correcto para tu consumo"
        idTitulo="comp-title"
      />
      <div class="comp-table-wrap">
        <table class="comp-table" aria-label="Comparativa de modelos">
          <thead>
            <tr>
              <th>Modelo</th><th>Personas</th><th>Precio instalado</th><th>Ideal para</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>10 tubos (115 L)</td><td>2-3 personas</td><td>$12,000-$14,000</td><td>Departamento o casa pequeña</td></tr>
            <tr><td>12-15 tubos (150 L)</td><td>3-4 personas</td><td>$14,000-$18,000</td><td>Casa estándar</td></tr>
            <tr><td>18-20 tubos (200 L)</td><td>4-6 personas</td><td>$18,000-$24,000</td><td>Casa mediana</td></tr>
            <tr><td>20-30 tubos (300 L)</td><td>6-8 personas</td><td>$24,000-$35,000</td><td>Casa grande o luxe</td></tr>
            
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes"
        subtitulo="Todo lo que necesitas saber sobre calentadores solares residenciales"
        idTitulo="faq-title"
      />
      <div class="faq">
        {faqItems.map((item, i) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.products-grid { margin-top: var(--space-4); }
.no-products {
  text-align: center; padding: var(--space-12);
  background: var(--color-bg-alt); border-radius: var(--radius-xl);
  display: flex; flex-direction: column; align-items: center; gap: var(--space-4);
}
.comp-table-wrap { overflow-x: auto; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.comp-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
.comp-table th {
  background: var(--color-dark); color: #fff;
  padding: var(--space-4) var(--space-5); text-align: left;
  font-weight: var(--weight-semibold); white-space: nowrap;
}
.comp-table td {
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text-secondary);
}
.comp-table tr:last-child td { border-bottom: none; }
.comp-table tr:nth-child(even) td { background: var(--color-bg-alt); }
</style>
