---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const allProducts = await getCollection('productos');
const products = allProducts.filter((p: CollectionEntry<'productos'>) => p.data.category === 'comercial');

const faqItems = [
  { pregunta: "¿Cómo se dimensiona un sistema para mi negocio?", respuesta: "Calculamos el volumen diario de agua caliente según el tipo de negocio y su capacidad, analizamos el techo disponible (orientación, área útil, estructura), diseñamos el sistema y presentamos propuesta con ROI detallado." },
  { pregunta: "¿Cuánto tiempo lleva instalar un proyecto comercial?", respuesta: "Proyectos medianos (hotel 20-30 habitaciones): 2-3 días. Sistemas grandes industriales: 1-2 semanas. Siempre coordinamos para minimizar el impacto en la operación del negocio." },
  { pregunta: "¿Qué garantías ofrecen en proyectos comerciales?", respuesta: "Garantía de equipo según fabricante (5-10 años en tanque), garantía de instalación 2 años, y plan de mantenimiento preventivo semestral disponible." },
  { pregunta: "¿Funciona en cualquier tipo de techo?", respuesta: "Funcionamos con techos planos (los más comunes en construcción comercial), techos inclinados y estructuras especiales. Evaluamos en la visita técnica gratuita." },
  { pregunta: "¿Pueden financiar proyectos grandes?", respuesta: "Para proyectos de más de $80,000 MXN ofrecemos esquemas de financiamiento propio con enganche del 30% y pagos a 12-18 meses. También asesoramos sobre créditos FIRA, FIDE y otros fondos para eficiencia energética." }
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares para Negocios y Proyectos Comerciales', description: 'Sistemas de calentamiento solar para hoteles, posadas, gimnasios, spas y restaurantes en México. Alta capacidad, diseño a medida y ROI en menos de 12 meses.', url: '/calentadores/comercial' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares para Negocios y Proyectos Comerciales', url: '/calentadores/comercial' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Comerciales | Hoteles, Gimnasios y Negocios"
  description="Sistemas de calentamiento solar para hoteles, posadas, gimnasios, spas y restaurantes en México. Alta capacidad, diseño a medida y ROI en menos de 12 meses."
  activePage="calentadores"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares para Negocios y Proyectos Comerciales', url: '/calentadores/comercial' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares para Negocios y Proyectos Comerciales"
  heroIntro="Sistemas de alta capacidad para hoteles, gimnasios, spas, restaurantes y cualquier negocio con alta demanda de agua caliente. ROI promedio: 10-14 meses."
  heroBadge="Proyectos comerciales"
  heroMetrics={[
        { valor: "500-5000L", texto: "Capacidad" },
    { valor: "80%", texto: "Ahorro gas" },
    { valor: "10-14 m", texto: "ROI promedio" },
    { valor: "Diseño a medida", texto: "" }
  ]}
  heroPrimaryText="Cotizar este sistema"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver todos los calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Por qué elegir este sistema -->
  <section class="section section--alt" aria-labelledby="why-title">
    <div class="container">
      <SectionHeader
        titulo="¿Por qué elegir Calentadores Solares para Negocios y Proyectos Comerciales?"
        subtitulo="Ventajas técnicas y económicas que hacen la diferencia"
        idTitulo="why-title"
        parrafo1="Los proyectos comerciales tienen características únicas: demanda concentrada en horas pico, altos volúmenes diarios y la posibilidad de un retorno de inversión extraordinariamente rápido. Un hotel que gasta $12,000/mes en gas para agua caliente puede recuperar la inversión solar en menos de un año."
        parrafo2="Cada proyecto comercial requiere un estudio de factibilidad individualizado: medición del techo disponible, análisis de la red hidráulica, cálculo de la demanda real y diseño del sistema óptimo. Este estudio es gratuito."
      />
    </div>
  </section>

  <!-- Productos del catálogo -->
  {products.length > 0 && (
    <section class="section" aria-labelledby="products-title">
      <div class="container">
        <SectionHeader
          titulo="Modelos disponibles"
          subtitulo="Selecciona el que mejor se adapta a tu consumo y presupuesto"
          enlaceTexto="Ver catálogo completo"
          enlaceUrl="/productos"
          idTitulo="products-title"
        />
        <div class="grid-3 products-grid">
          {products.map((p: CollectionEntry<'productos'>, i: number) => (
            <ProductCard
              titulo={p.data.title}
              descripcion={p.data.description}
              enlace={`/productos/${p.slug}`}
              imagen={p.data.image.startsWith('/img') ? p.data.image : '/img/categorias/calentador-solar-residencial-casa-cdmx.avif'}
              precio={p.data.price}
              precioMin={p.data.priceRangeMin}
              precioMax={p.data.priceRangeMax}
              capacidad={p.data.capacityLiters}
              tubos={p.data.tubeCount}
              usuarios={p.data.targetUsers}
              features={p.data.features}
              featured={i === 0}
            />
          ))}
        </div>
        {products.length === 0 && (
          <div class="no-products">
            <p>Contáctanos para conocer los modelos disponibles para este tipo de sistema.</p>
            <a href="/cotizar" class="btn btn--primary">Solicitar cotización →</a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Tabla comparativa -->
  <section class="section section--alt" aria-labelledby="comp-title">
    <div class="container" style="max-width: 900px;">
      <SectionHeader
        titulo="Comparativa de modelos"
        subtitulo="Elige el tamaño correcto para tu consumo"
        idTitulo="comp-title"
      />
      <div class="comp-table-wrap">
        <table class="comp-table" aria-label="Comparativa de modelos">
          <thead>
            <tr>
              <th>Tipo de negocio</th><th>Demanda diaria</th><th>Inversión estimada</th><th>ROI aproximado</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Hotel 20 hab.</td><td>~1,600 L/día</td><td>$85,000-$120,000</td><td>~12 meses</td></tr>
            <tr><td>Gimnasio 200 socios</td><td>~3,000 L/día</td><td>$130,000-$180,000</td><td>~10 meses</td></tr>
            <tr><td>Restaurante grande</td><td>~800 L/día</td><td>$65,000-$90,000</td><td>~8 meses</td></tr>
            <tr><td>Spa / centro wellness</td><td>~1,200 L/día</td><td>$95,000-$150,000</td><td>~11 meses</td></tr>
            
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes"
        subtitulo="Todo lo que necesitas saber sobre calentadores solares para negocios y proyectos comerciales"
        idTitulo="faq-title"
      />
      <div class="faq">
        {faqItems.map((item, i) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.products-grid { margin-top: var(--space-4); }
.no-products {
  text-align: center; padding: var(--space-12);
  background: var(--color-bg-alt); border-radius: var(--radius-xl);
  display: flex; flex-direction: column; align-items: center; gap: var(--space-4);
}
.comp-table-wrap { overflow-x: auto; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.comp-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
.comp-table th {
  background: var(--color-dark); color: #fff;
  padding: var(--space-4) var(--space-5); text-align: left;
  font-weight: var(--weight-semibold); white-space: nowrap;
}
.comp-table td {
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text-secondary);
}
.comp-table tr:last-child td { border-bottom: none; }
.comp-table tr:nth-child(even) td { background: var(--color-bg-alt); }
</style>
