---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const allProducts = await getCollection('productos');
const products = allProducts.filter((p: CollectionEntry<'productos'>) => p.data.category === 'de-paso-solar');

const faqItems = [
  { pregunta: "¿En qué clima funciona mejor el de paso solar?", respuesta: "En zonas con temperatura ambiente alta todo el año: costas del Pacífico y Golfo, Oaxaca, Chiapas, norte árido (Sonora, Chihuahua). En CDMX y el altiplano es menos eficiente en invierno porque el agua fría requiere más calentamiento." },
  { pregunta: "¿Necesita mantenimiento diferente?", respuesta: "Al no tener tanque, no necesita cambio de ánodo ni limpieza interior del tanque. Solo revisión anual del colector y conexiones." },
  { pregunta: "¿Cuánto cuesta comparado con sistema de tanque?", respuesta: "El sistema de paso es 25-35% más económico que uno con tanque equivalente. Sin embargo, tiene limitaciones de rendimiento en climas fríos." },
  { pregunta: "¿Puede instalarse en departamento?", respuesta: "Sí, es ideal para departamentos con poco espacio en azotea ya que no tiene tanque y el colector es delgado y liviano." },
  { pregunta: "¿Qué pasa si no hay sol durante varios días?", respuesta: "A diferencia del sistema con tanque (que retiene agua caliente 24-36h), el sistema de paso no tiene almacenamiento. Se necesita respaldo de gas para días sin sol." }
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares de Paso: Flujo Continuo sin Tanque', description: 'Sistemas solares de paso instantáneo para zonas cálidas en México. Sin tanque, agua caliente continua con bajo perfil de instalación. Ideal para climas tropicales.', url: '/calentadores/de-paso-solar' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares de Paso: Flujo Continuo sin Tanque', url: '/calentadores/de-paso-solar' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares de Paso | Agua Caliente al Instante con Energía Solar"
  description="Sistemas solares de paso instantáneo para zonas cálidas en México. Sin tanque, agua caliente continua con bajo perfil de instalación. Ideal para climas tropicales."
  activePage="calentadores"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares de Paso: Flujo Continuo sin Tanque', url: '/calentadores/de-paso-solar' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares de Paso: Flujo Continuo sin Tanque"
  heroIntro="La solución más compacta: calientas el agua directamente al fluir por el colector solar. Sin tanque de almacenamiento, sin pérdidas de calor nocturnas, menor espacio en techo."
  heroBadge="Sistema compacto"
  heroMetrics={[
        { valor: "Sin tanque", texto: "Diseño" },
    { valor: "Instantáneo", texto: "Flujo" },
    { valor: "Climas cálidos", texto: "Óptimo" },
    { valor: "–60%", texto: "En gas" }
  ]}
  heroPrimaryText="Cotizar este sistema"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver todos los calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Por qué elegir este sistema -->
  <section class="section section--alt" aria-labelledby="why-title">
    <div class="container">
      <SectionHeader
        titulo="¿Por qué elegir Calentadores Solares de Paso: Flujo Continuo sin Tanque?"
        subtitulo="Ventajas técnicas y económicas que hacen la diferencia"
        idTitulo="why-title"
        parrafo1="El calentador solar de paso es un sistema donde el agua fluye directamente a través del colector solar y sale caliente hacia los puntos de uso, sin almacenarse en un tanque. Es el sistema más simple posible: solo el colector y la red hidráulica."
        parrafo2="Funciona mejor en climas cálidos con mucho sol (costas, Oaxaca, Chiapas, norte de México). En el altiplano central como CDMX, donde las noches son frías y se necesita agua caliente en la madrugada, un sistema con tanque es preferible."
      />
    </div>
  </section>

  <!-- Productos del catálogo -->
  {products.length > 0 && (
    <section class="section" aria-labelledby="products-title">
      <div class="container">
        <SectionHeader
          titulo="Modelos disponibles"
          subtitulo="Selecciona el que mejor se adapta a tu consumo y presupuesto"
          enlaceTexto="Ver catálogo completo"
          enlaceUrl="/productos"
          idTitulo="products-title"
        />
        <div class="grid-3 products-grid">
          {products.map((p: CollectionEntry<'productos'>, i: number) => (
            <ProductCard
              titulo={p.data.title}
              descripcion={p.data.description}
              enlace={`/productos/${p.slug}`}
              imagen={p.data.image.startsWith('/img') ? p.data.image : '/img/categorias/calentador-solar-residencial-casa-cdmx.avif'}
              precio={p.data.price}
              precioMin={p.data.priceRangeMin}
              precioMax={p.data.priceRangeMax}
              capacidad={p.data.capacityLiters}
              tubos={p.data.tubeCount}
              usuarios={p.data.targetUsers}
              features={p.data.features}
              featured={i === 0}
            />
          ))}
        </div>
        {products.length === 0 && (
          <div class="no-products">
            <p>Contáctanos para conocer los modelos disponibles para este tipo de sistema.</p>
            <a href="/cotizar" class="btn btn--primary">Solicitar cotización →</a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Tabla comparativa -->
  <section class="section section--alt" aria-labelledby="comp-title">
    <div class="container" style="max-width: 900px;">
      <SectionHeader
        titulo="Comparativa de modelos"
        subtitulo="Elige el tamaño correcto para tu consumo"
        idTitulo="comp-title"
      />
      <div class="comp-table-wrap">
        <table class="comp-table" aria-label="Comparativa de modelos">
          <thead>
            <tr>
              <th>Sistema</th><th>Configuración</th><th>Clima</th><th>Ventaja</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Paso solar</td><td>Sin tanque</td><td>Climas cálidos</td><td>Más económico</td></tr>
            <tr><td>Tubos evacuados + tanque</td><td>Con tanque 100-300L</td><td>Todo México</td><td>Más versátil</td></tr>
            <tr><td>Presurizado</td><td>Con tanque + bomba</td><td>Todo México</td><td>Máximo rendimiento</td></tr>
            
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes"
        subtitulo="Todo lo que necesitas saber sobre calentadores solares de paso: flujo continuo sin tanque"
        idTitulo="faq-title"
      />
      <div class="faq">
        {faqItems.map((item, i) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.products-grid { margin-top: var(--space-4); }
.no-products {
  text-align: center; padding: var(--space-12);
  background: var(--color-bg-alt); border-radius: var(--radius-xl);
  display: flex; flex-direction: column; align-items: center; gap: var(--space-4);
}
.comp-table-wrap { overflow-x: auto; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.comp-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
.comp-table th {
  background: var(--color-dark); color: #fff;
  padding: var(--space-4) var(--space-5); text-align: left;
  font-weight: var(--weight-semibold); white-space: nowrap;
}
.comp-table td {
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text-secondary);
}
.comp-table tr:last-child td { border-bottom: none; }
.comp-table tr:nth-child(even) td { background: var(--color-bg-alt); }
</style>
