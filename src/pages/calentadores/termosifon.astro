---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const allProducts = await getCollection('productos');
const products = allProducts.filter((p: CollectionEntry<'productos'>) => p.data.category === 'termosifon');

const faqItems = [
  { pregunta: "¿Por qué el termosifón no necesita electricidad?", respuesta: "Funciona por convección natural: el agua caliente es menos densa y sube sola al tanque, el agua fría baja al colector por gravedad. Es física pura, sin partes eléctricas." },
  { pregunta: "¿El tanque puede estar al mismo nivel que los tubos?", respuesta: "No. El tanque debe estar al menos 30 cm por encima del colector para que la convección funcione. En práctica, en azoteas estándar esto siempre se cumple." },
  { pregunta: "¿Cómo se compara con el presurizado?", respuesta: "El termosifón es más económico (20-30% menos), más simple y más duradero (sin bomba que desgastar). El presurizado gana en flexibilidad de instalación y rendimiento en días con poca radiación." },
  { pregunta: "¿Qué pasa en días sin sol?", respuesta: "El tanque de acero inoxidable con aislamiento de poliuretano mantiene el agua caliente 24-36 horas. Si el día anterior fue soleado, tienes agua caliente aunque hoy esté nublado." },
  { pregunta: "¿Cuánto ahorro con el termosifón vs gas?", respuesta: "Exactamente lo mismo que con el presurizado: 70-80% anual. La diferencia no está en el ahorro sino en la flexibilidad de instalación." }
];

const structuredData = [
  buildServiceSchema({ name: 'Calentadores Solares Termosifón', description: 'Calentadores solares de termosifón para casas en México. Sin bomba, sin electricidad, máxima confiabilidad. El modelo más vendido en el mercado residencial mexicano.', url: '/calentadores/termosifon' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares Termosifón', url: '/calentadores/termosifon' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Termosifón | Clásico, Confiable y Económico"
  description="Calentadores solares de termosifón para casas en México. Sin bomba, sin electricidad, máxima confiabilidad. El modelo más vendido en el mercado residencial mexicano."
  activePage="calentadores"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Calentadores Solares Termosifón', url: '/calentadores/termosifon' },
  ]}
  showHero={true}
  heroTitle="Calentadores Solares Termosifón"
  heroIntro="El sistema más simple y confiable del mercado solar. Sin bomba, sin electrónica, sin fallas. El agua sube sola por convección y se mantiene caliente 24+ horas."
  heroBadge="El más confiable"
  heroMetrics={[
        { valor: "115-300L", texto: "Capacidad" },
    { valor: "0W", texto: "Consumo eléctrico" },
    { valor: "Sin bomba", texto: "Operación" },
    { valor: "20 años", texto: "Durabilidad" }
  ]}
  heroPrimaryText="Cotizar este sistema"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver todos los calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Por qué elegir este sistema -->
  <section class="section section--alt" aria-labelledby="why-title">
    <div class="container">
      <SectionHeader
        titulo="¿Por qué elegir Calentadores Solares Termosifón?"
        subtitulo="Ventajas técnicas y económicas que hacen la diferencia"
        idTitulo="why-title"
        parrafo1="El termosifón es la tecnología más probada en calentadores solares: el agua fría baja al colector por gravedad, se calienta en los tubos evacuados y sube al tanque por convección natural. Sin partes móviles eléctricas, sin controladores que puedan fallar."
        parrafo2="La condición única es que el tanque debe estar físicamente más alto que los colectores. En casas con azotea y tinaco, esto es natural. Si tienes tinaco, el termosifón es casi siempre la mejor opción."
      />
    </div>
  </section>

  <!-- Productos del catálogo -->
  {products.length > 0 && (
    <section class="section" aria-labelledby="products-title">
      <div class="container">
        <SectionHeader
          titulo="Modelos disponibles"
          subtitulo="Selecciona el que mejor se adapta a tu consumo y presupuesto"
          enlaceTexto="Ver catálogo completo"
          enlaceUrl="/productos"
          idTitulo="products-title"
        />
        <div class="grid-3 products-grid">
          {products.map((p: CollectionEntry<'productos'>, i: number) => (
            <ProductCard
              titulo={p.data.title}
              descripcion={p.data.description}
              enlace={`/productos/${p.slug}`}
              imagen={p.data.image.startsWith('/img') ? p.data.image : '/img/categorias/calentador-solar-residencial-casa-cdmx.avif'}
              precio={p.data.price}
              precioMin={p.data.priceRangeMin}
              precioMax={p.data.priceRangeMax}
              capacidad={p.data.capacityLiters}
              tubos={p.data.tubeCount}
              usuarios={p.data.targetUsers}
              features={p.data.features}
              featured={i === 0}
            />
          ))}
        </div>
        {products.length === 0 && (
          <div class="no-products">
            <p>Contáctanos para conocer los modelos disponibles para este tipo de sistema.</p>
            <a href="/cotizar" class="btn btn--primary">Solicitar cotización →</a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Tabla comparativa -->
  <section class="section section--alt" aria-labelledby="comp-title">
    <div class="container" style="max-width: 900px;">
      <SectionHeader
        titulo="Comparativa de modelos"
        subtitulo="Elige el tamaño correcto para tu consumo"
        idTitulo="comp-title"
      />
      <div class="comp-table-wrap">
        <table class="comp-table" aria-label="Comparativa de modelos">
          <thead>
            <tr>
              <th>Tubos</th><th>Capacidad</th><th>Personas</th><th>Tipo de inmueble</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>10 tubos</td><td>115 L</td><td>2-3 personas</td><td>Departamento / casa chica</td></tr>
            <tr><td>15 tubos</td><td>150 L</td><td>3-4 personas</td><td>Casa estándar</td></tr>
            <tr><td>20 tubos</td><td>200 L</td><td>5-6 personas</td><td>Casa mediana</td></tr>
            <tr><td>30 tubos</td><td>300 L</td><td>7-9 personas</td><td>Casa grande</td></tr>
            
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes"
        subtitulo="Todo lo que necesitas saber sobre calentadores solares termosifón"
        idTitulo="faq-title"
      />
      <div class="faq">
        {faqItems.map((item, i) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.products-grid { margin-top: var(--space-4); }
.no-products {
  text-align: center; padding: var(--space-12);
  background: var(--color-bg-alt); border-radius: var(--radius-xl);
  display: flex; flex-direction: column; align-items: center; gap: var(--space-4);
}
.comp-table-wrap { overflow-x: auto; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.comp-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
.comp-table th {
  background: var(--color-dark); color: #fff;
  padding: var(--space-4) var(--space-5); text-align: left;
  font-weight: var(--weight-semibold); white-space: nowrap;
}
.comp-table td {
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text-secondary);
}
.comp-table tr:last-child td { border-bottom: none; }
.comp-table tr:nth-child(even) td { background: var(--color-bg-alt); }
</style>
