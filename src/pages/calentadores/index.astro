---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';

const faqItems = [
  { pregunta: '¿Cuál es la diferencia entre termosifón y presurizado?', respuesta: 'El termosifón usa convección natural (sin bomba, más económico, requiere tanque elevado). El presurizado usa bomba eléctrica de bajo consumo y puede instalar el tanque en cualquier posición. Para casas estándar con tinaco, el termosifón es suficiente.' },
  { pregunta: '¿Qué sistema conviene para una casa de 4 personas en CDMX?', respuesta: 'Un calentador residencial de 18-20 tubos (180-200 litros), tipo termosifón si tienen tinaco, o presurizado si tienen sistema hidro-neumático. El costo instalado ronda los $18,000-$22,000 MXN con ROI en menos de 2 años.' },
  { pregunta: '¿Los calentadores solares funcionan en toda la República?', respuesta: 'Sí. México tiene uno de los mejores recursos solares del mundo. El altiplano (CDMX, Querétaro, Puebla) tiene excelente rendimiento. La costa y el norte árido son aún mejores. Solo la zona sur húmeda (Tabasco, Veracruz costa) requiere sistemas sobredimensionados.' },
  { pregunta: '¿Cuándo conviene un sistema comercial vs residencial?', respuesta: 'Si el consumo supera los 400-500 litros diarios (hotel, gimnasio, restaurante) o si hay múltiples puntos de uso simultáneo, un sistema comercial modular es más eficiente que varios sistemas residenciales.' },
];

const structuredData = [
  buildBreadcrumbSchema([{ name: 'Inicio', url: '/' }, { name: 'Calentadores', url: '/calentadores' }]),
  buildFAQSchema(faqItems),
];
---

<BaseLayout
  title="Tipos de Calentadores Solares | Guía Completa — De Calentadores Solares"
  description="Guía de los tipos de calentadores solares en México: residencial, presurizado, termosifón, comercial e industrial. Comparativa técnica y cuál elegir."
  activePage="calentadores"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Calentadores', url: '/calentadores' }]}
  showHero={true}
  heroTitle="Tipos de Calentadores Solares en México"
  heroIntro="De sistemas residenciales sencillos a instalaciones industriales de alta capacidad. Encuentra el sistema exacto para tu consumo y presupuesto."
  heroBadge="Guía de selección"
  heroMetrics={[
    { valor: '6', texto: 'Tipos de sistema' },
    { valor: '115-5000L', texto: 'Rango de capacidad' },
    { valor: '80%', texto: 'Ahorro máximo' },
    { valor: 'Gratis', texto: 'Asesoría técnica' },
  ]}
  heroPrimaryText="Asesoría gratuita"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver catálogo"
  heroSecondaryLink="/productos"
>

  <!-- Tipos de sistemas -->
  <section class="section" aria-labelledby="tipos-title">
    <div class="container">
      <SectionHeader
        titulo="¿Qué tipo de calentador solar necesitas?"
        subtitulo="Cada uso tiene su solución óptima. Conoce las opciones y sus diferencias."
        idTitulo="tipos-title"
        parrafo1="No existe un 'mejor calentador solar' universal. La elección correcta depende del número de personas, el tipo de inmueble, la red hidráulica disponible, el clima de tu zona y el presupuesto. Esta guía te ayuda a identificar el sistema correcto."
        parrafo2="Si tienes dudas después de leer, nuestra asesoría técnica es gratuita y sin compromiso. Te calculamos la capacidad exacta y te recomendamos el modelo adecuado para tu caso en menos de 24 horas."
      />

      <div class="grid-3 tipos-grid">
        <CategoryCard
          titulo="Residencial"
          subtitulo="Para casas y familias de 2 a 8 personas"
          enlace="/calentadores/residencial"
          imagen="/img/categorias/calentador-solar-residencial-casa-cdmx.avif"
          icono="🏠"
          tipos={[
            { nombre: '10 tubos — 115 L (2-3 personas)', enlace: '/calentadores/residencial' },
            { nombre: '15 tubos — 150 L (3-4 personas)', enlace: '/calentadores/residencial' },
            { nombre: '18-20 tubos — 200 L (4-6 personas)', enlace: '/calentadores/residencial' },
            { nombre: '30 tubos — 300 L (6-8 personas)', enlace: '/calentadores/residencial' },
          ]}
        />
        <CategoryCard
          titulo="Presurizado"
          subtitulo="Alta presión, compatible con cualquier instalación"
          enlace="/calentadores/presurizado"
          imagen="/img/categorias/calentador-solar-presurizado-alta-presion.avif"
          icono="💧"
          tipos={[
            { nombre: 'Presurizado 150 L', enlace: '/calentadores/presurizado' },
            { nombre: 'Presurizado 200 L', enlace: '/calentadores/presurizado' },
            { nombre: 'Presurizado 300 L', enlace: '/calentadores/presurizado' },
            { nombre: 'Para edificios y departamentos', enlace: '/calentadores/presurizado' },
          ]}
        />
        <CategoryCard
          titulo="Termosifón"
          subtitulo="Clásico, sin bomba, máxima confiabilidad"
          enlace="/calentadores/termosifon"
          imagen="/img/categorias/calentador-solar-residencial-casa-cdmx.avif"
          icono="♻️"
          tipos={[
            { nombre: 'Termosifón 115 L', enlace: '/calentadores/termosifon' },
            { nombre: 'Termosifón 150-200 L', enlace: '/calentadores/termosifon' },
            { nombre: 'Termosifón 300 L', enlace: '/calentadores/termosifon' },
            { nombre: '0W de consumo eléctrico', enlace: '/calentadores/termosifon' },
          ]}
        />
        <CategoryCard
          titulo="Comercial"
          subtitulo="Hoteles, gimnasios, spas y restaurantes"
          enlace="/calentadores/comercial"
          imagen="/img/categorias/calentador-solar-comercial-hotel-mexico.avif"
          icono="🏨"
          tipos={[
            { nombre: 'Para hotel y posada', enlace: '/calentadores/comercial' },
            { nombre: 'Para gimnasio y spa', enlace: '/calentadores/comercial' },
            { nombre: 'Para restaurante', enlace: '/calentadores/comercial' },
            { nombre: 'Diseño a medida', enlace: '/servicios/proyectos-comerciales' },
          ]}
        />
        <CategoryCard
          titulo="Industrial"
          subtitulo="Procesos industriales de alta capacidad"
          enlace="/calentadores/industrial"
          imagen="/img/categorias/calentador-solar-comercial-hotel-mexico.avif"
          icono="🏭"
          tipos={[
            { nombre: 'Sistemas +5,000 L/día', enlace: '/calentadores/industrial' },
            { nombre: 'Integración con caldera', enlace: '/calentadores/industrial' },
            { nombre: 'Ingeniería de detalle', enlace: '/calentadores/industrial' },
            { nombre: 'Financiamiento disponible', enlace: '/calentadores/industrial' },
          ]}
        />
        <CategoryCard
          titulo="Paso solar"
          subtitulo="Sin tanque, compacto, ideal para climas cálidos"
          enlace="/calentadores/de-paso-solar"
          imagen="/img/categorias/calentador-solar-residencial-casa-cdmx.avif"
          icono="⚡"
          tipos={[
            { nombre: 'Sin tanque de almacenamiento', enlace: '/calentadores/de-paso-solar' },
            { nombre: 'Ideal para clima tropical', enlace: '/calentadores/de-paso-solar' },
            { nombre: 'Bajo perfil de instalación', enlace: '/calentadores/de-paso-solar' },
            { nombre: 'Más económico', enlace: '/calentadores/de-paso-solar' },
          ]}
        />
      </div>
    </div>
  </section>

  <!-- Tabla comparativa rápida -->
  <section class="section section--alt" aria-labelledby="comp-title">
    <div class="container">
      <SectionHeader
        titulo="Comparativa rápida de sistemas"
        subtitulo="¿Cuál te conviene? Esta tabla simplifica la decisión"
        idTitulo="comp-title"
      />
      <div style="overflow-x:auto; border-radius: var(--radius-xl); border: 1px solid var(--color-border);">
        <table style="width:100%; border-collapse:collapse; font-size: var(--text-sm);">
          <thead>
            <tr>
              <th style="background:var(--color-dark);color:#fff;padding:var(--space-4) var(--space-5);text-align:left;">Sistema</th>
              <th style="background:var(--color-dark);color:#fff;padding:var(--space-4) var(--space-5);text-align:left;">Capacidad</th>
              <th style="background:var(--color-dark);color:#fff;padding:var(--space-4) var(--space-5);text-align:left;">Precio aprox.</th>
              <th style="background:var(--color-dark);color:#fff;padding:var(--space-4) var(--space-5);text-align:left;">ROI</th>
              <th style="background:var(--color-dark);color:#fff;padding:var(--space-4) var(--space-5);text-align:left;">Ideal para</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Residencial termosifón', '115-300 L', '$12,000-$30,000', '18-24 meses', 'Casa con tinaco'],
              ['Residencial presurizado', '150-500 L', '$16,000-$45,000', '20-28 meses', 'Hidro-neumático / edificio'],
              ['Paso solar', '50-120 L', '$8,000-$14,000', '12-18 meses', 'Clima cálido / departamento'],
              ['Comercial', '500-5000 L', '$65,000-$200,000', '8-14 meses', 'Hotel / gimnasio / restaurante'],
              ['Industrial', '+5000 L', '$280,000+', '10-14 meses', 'Manufactura / procesadora'],
            ].map((row, i) => (
              <tr>
                {row.map((cell, j) => (
                  <td style={`padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--color-border); color: var(--color-text-secondary); background: ${i % 2 === 1 ? 'var(--color-bg-alt)' : 'white'}; font-weight: ${j === 0 ? 'var(--weight-semibold)' : 'normal'};`}>{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="text-align:center;margin-top:var(--space-6);font-size:var(--text-sm);color:var(--color-text-muted);">
        * Precios orientativos. El precio exacto depende del modelo, la instalación y la zona. <a href="/cotizar" style="color:var(--color-brand);font-weight:var(--weight-semibold);">Solicita cotización →</a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-cal-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader titulo="Preguntas frecuentes" subtitulo="Resolvemos las dudas más comunes antes de comprar" idTitulo="faq-cal-title" />
      <div class="faq">
        {faqItems.map(item => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>
