---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildServiceSchema, buildFAQSchema, buildBreadcrumbSchema } from '../../lib/seo';

const allProducts = await getCollection('productos');
const products = allProducts.filter((p: CollectionEntry<'productos'>) => p.data.category === 'industrial');

const faqItems = [
  { pregunta: "¿A qué temperatura llega el agua con sistema industrial?", respuesta: "Los sistemas industriales pueden alcanzar temperaturas de 60-95°C según el diseño. Para aplicaciones que requieren más temperatura se usan colectores de concentración parabólica." },
  { pregunta: "¿Pueden integrarse con el sistema de vapor existente?", respuesta: "Sí. El sistema solar se integra como precalentador al sistema de vapor o caldera existente, reduciendo el combustible necesario sin reemplazar la infraestructura actual." },
  { pregunta: "¿Qué normas aplican a instalaciones industriales?", respuesta: "NOM-001-SEDE (instalaciones eléctricas), NOM-020-STPS (recipientes sujetos a presión), y dependiendo del sector: NOM-251-SSA1 para alimentos, entre otras." },
  { pregunta: "¿Ofrecen servicio de ingeniería de detalle?", respuesta: "Sí. Para proyectos industriales elaboramos ingeniería de detalle: planos isométricos, memoria de cálculo, especificaciones técnicas completas y acompañamiento en la gestión con protección civil si aplica." },
  { pregunta: "¿Cuál es el tiempo de respuesta para proyectos industriales?", respuesta: "Visita técnica: 3-5 días hábiles. Propuesta técnico-económica: 5-10 días. Instalación: según complejidad, de 2 semanas a 2 meses para proyectos grandes." }
];

const structuredData = [
  buildServiceSchema({ name: 'Sistemas Solares Industriales de Alta Capacidad', description: 'Sistemas solares térmicos industriales para procesos de alta temperatura y gran volumen en México. Diseño de ingeniería, instalación certificada y soporte técnico.', url: '/calentadores/industrial' }),
  buildFAQSchema(faqItems),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Sistemas Solares Industriales de Alta Capacidad', url: '/calentadores/industrial' },
  ]),
];
---

<BaseLayout
  title="Calentadores Solares Industriales | Alta Capacidad para Industria"
  description="Sistemas solares térmicos industriales para procesos de alta temperatura y gran volumen en México. Diseño de ingeniería, instalación certificada y soporte técnico."
  activePage="calentadores"
  structuredData={structuredData}
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Calentadores', url: '/calentadores' },
    { name: 'Sistemas Solares Industriales de Alta Capacidad', url: '/calentadores/industrial' },
  ]}
  showHero={true}
  heroTitle="Sistemas Solares Industriales de Alta Capacidad"
  heroIntro="Soluciones de calentamiento solar para procesos industriales: lavandería, manufactura, alimentos y bebidas, farmacéutica y cualquier proceso con demanda de agua caliente o vapor."
  heroBadge="Alta capacidad"
  heroMetrics={[
        { valor: "+5000L", texto: "Capacidad" },
    { valor: "70-85%", texto: "Sustitución GN/LP" },
    { valor: "Ingeniería", texto: "Diseño a medida" },
    { valor: "ISO", texto: "Estándares" }
  ]}
  heroPrimaryText="Cotizar este sistema"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver todos los calentadores"
  heroSecondaryLink="/calentadores"
>

  <!-- Por qué elegir este sistema -->
  <section class="section section--alt" aria-labelledby="why-title">
    <div class="container">
      <SectionHeader
        titulo="¿Por qué elegir Sistemas Solares Industriales de Alta Capacidad?"
        subtitulo="Ventajas técnicas y económicas que hacen la diferencia"
        idTitulo="why-title"
        parrafo1="El calentamiento de agua es uno de los mayores consumidores de energía en la industria mexicana. Las plantas de manufactura, lavanderías industriales, procesadoras de alimentos y empresas farmacéuticas consumen miles de litros de agua caliente al día, pagando enormes facturas de gas natural o LP."
        parrafo2="Los sistemas solares industriales pueden sustituir entre el 50% y el 85% de ese consumo según el proceso y la zona geográfica. A esta escala, el ahorro puede representar millones de pesos anuales."
      />
    </div>
  </section>

  <!-- Productos del catálogo -->
  {products.length > 0 && (
    <section class="section" aria-labelledby="products-title">
      <div class="container">
        <SectionHeader
          titulo="Modelos disponibles"
          subtitulo="Selecciona el que mejor se adapta a tu consumo y presupuesto"
          enlaceTexto="Ver catálogo completo"
          enlaceUrl="/productos"
          idTitulo="products-title"
        />
        <div class="grid-3 products-grid">
          {products.map((p: CollectionEntry<'productos'>, i: number) => (
            <ProductCard
              titulo={p.data.title}
              descripcion={p.data.description}
              enlace={`/productos/${p.slug}`}
              imagen={p.data.image.startsWith('/img') ? p.data.image : '/img/categorias/calentador-solar-residencial-casa-cdmx.avif'}
              precio={p.data.price}
              precioMin={p.data.priceRangeMin}
              precioMax={p.data.priceRangeMax}
              capacidad={p.data.capacityLiters}
              tubos={p.data.tubeCount}
              usuarios={p.data.targetUsers}
              features={p.data.features}
              featured={i === 0}
            />
          ))}
        </div>
        {products.length === 0 && (
          <div class="no-products">
            <p>Contáctanos para conocer los modelos disponibles para este tipo de sistema.</p>
            <a href="/cotizar" class="btn btn--primary">Solicitar cotización →</a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Tabla comparativa -->
  <section class="section section--alt" aria-labelledby="comp-title">
    <div class="container" style="max-width: 900px;">
      <SectionHeader
        titulo="Comparativa de modelos"
        subtitulo="Elige el tamaño correcto para tu consumo"
        idTitulo="comp-title"
      />
      <div class="comp-table-wrap">
        <table class="comp-table" aria-label="Comparativa de modelos">
          <thead>
            <tr>
              <th>Escala</th><th>Aplicación</th><th>Inversión aprox.</th><th>ROI aprox.</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Sistema 5,000 L</td><td>Lavandería mediana / planta pequeña</td><td>~$280,000</td><td>~14 meses</td></tr>
            <tr><td>Sistema 10,000 L</td><td>Planta manufactura / hospital</td><td>~$480,000</td><td>~12 meses</td></tr>
            <tr><td>Sistema 20,000 L</td><td>Procesadora alimentos / farmacéutica</td><td>~$850,000</td><td>~10 meses</td></tr>
            
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-title">
    <div class="container" style="max-width: 780px;">
      <SectionHeader
        titulo="Preguntas frecuentes"
        subtitulo="Todo lo que necesitas saber sobre sistemas solares industriales de alta capacidad"
        idTitulo="faq-title"
      />
      <div class="faq">
        {faqItems.map((item, i) => (
          <div class="faq__item">
            <button class="faq__question" aria-expanded="false">
              {item.pregunta}<span class="faq__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq__answer"><p>{item.respuesta}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
.products-grid { margin-top: var(--space-4); }
.no-products {
  text-align: center; padding: var(--space-12);
  background: var(--color-bg-alt); border-radius: var(--radius-xl);
  display: flex; flex-direction: column; align-items: center; gap: var(--space-4);
}
.comp-table-wrap { overflow-x: auto; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
.comp-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
.comp-table th {
  background: var(--color-dark); color: #fff;
  padding: var(--space-4) var(--space-5); text-align: left;
  font-weight: var(--weight-semibold); white-space: nowrap;
}
.comp-table td {
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text-secondary);
}
.comp-table tr:last-child td { border-bottom: none; }
.comp-table tr:nth-child(even) td { background: var(--color-bg-alt); }
</style>
