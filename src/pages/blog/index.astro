---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import BlogCard from '../../components/BlogCard.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import { buildBreadcrumbSchema, buildCollectionPageSchema, buildItemListSchema } from '../../lib/seo';

import type { CollectionEntry } from 'astro:content';
type BlogPost = CollectionEntry<'blog'>;

const allPosts = (await getCollection('blog', ({ data }: { data: BlogPost['data'] }) => !data.draft))
  .sort((a: BlogPost, b: BlogPost) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

// Categorías con conteo
const cats = allPosts.reduce((acc: Record<string, number>, p: BlogPost) => {
  acc[p.data.category] = (acc[p.data.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categorias = (Object.entries(cats) as [string, number][]).sort((a, b) => b[1] - a[1]);

const structuredData = [
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Blog', url: '/blog' },
  ]),
  buildCollectionPageSchema('Blog de Calentadores Solares', 'Artículos técnicos sobre calentadores solares en México: guías de compra, mantenimiento, ahorro, comparativas y proyectos.', '/blog'),
  buildItemListSchema('Artículos recientes', allPosts.slice(0, 10).map((p: BlogPost, i: number) => ({
    name: p.data.title,
    url: `/blog/${p.slug}`,
    image: p.data.image,
    position: i + 1,
  }))),
];
---

<BaseLayout
  title="Blog de Calentadores Solares | Guías y Consejos — De Calentadores Solares"
  description="Artículos técnicos sobre calentadores solares en México: guías de compra, mantenimiento, ahorro, comparativas y proyectos. Contenido profesional actualizado."
  activePage="blog"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Blog', url: '/blog' }]}
  showHero={true}
  heroTitle="Blog de Calentadores Solares"
  heroIntro="Guías técnicas, comparativas y consejos para elegir, instalar y mantener tu calentador solar. Contenido profesional basado en 15 años de experiencia en México."
  heroBadge="Recursos y Guías"
  heroMetrics={[
    { valor: `${allPosts.length}+`, texto: 'Artículos' },
    { valor: categorias.length.toString(), texto: 'Categorías' },
    { valor: 'Gratis', texto: 'Contenido experto' },
  ]}
  heroPrimaryText="Solicitar asesoría"
  heroPrimaryLink="/cotizar"
  heroSecondaryText="Ver calentadores"
  heroSecondaryLink="/productos"
>

  <section class="section">
    <div class="container">

      <!-- Filtros por categoría -->
      <div class="blog-filters" aria-label="Filtrar por categoría">
        <a href="/blog" class="blog-filter blog-filter--active">Todos ({allPosts.length})</a>
        {categorias.map(([cat, count]) => (
          <a href={`/blog/categoria/${cat.toLowerCase()}`} class="blog-filter">{cat} ({count})</a>
        ))}
      </div>

      <!-- Artículo destacado (el más reciente) -->
      {allPosts.length > 0 && (
        <div class="blog-featured" aria-label="Artículo destacado">
          <a href={`/blog/${allPosts[0].slug}`} class="blog-featured__img-link">
            <div class="blog-featured__img-wrap">
              <img
                src={allPosts[0].data.image}
                alt={allPosts[0].data.imageAlt}
                class="blog-featured__img"
                loading="eager"
                decoding="async"
                width="880"
                height="495"
              />
              <span class="blog-card__cat">{allPosts[0].data.category}</span>
            </div>
          </a>
          <div class="blog-featured__body">
            <h2 class="blog-featured__title">
              <a href={`/blog/${allPosts[0].slug}`}>{allPosts[0].data.title}</a>
            </h2>
            <p class="blog-featured__desc">{allPosts[0].data.description}</p>
            <div class="blog-featured__tags">
              {allPosts[0].data.tags.slice(0, 3).map((tag: string) => (
                <span class="blog-featured__tag">{tag}</span>
              ))}
            </div>
            <a href={`/blog/${allPosts[0].slug}`} class="btn btn--primary">Leer artículo completo →</a>
          </div>
        </div>
      )}

      <!-- Grid de artículos -->
      <div class="grid-3 blog-grid" aria-label="Artículos del blog">
        {allPosts.slice(1).map((post: BlogPost) => (
          <BlogCard
            titulo={post.data.title}
            descripcion={post.data.description}
            enlace={`/blog/${post.slug}`}
            imagen={post.data.image}
            imageAlt={post.data.imageAlt}
            categoria={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>

    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
/* Filtros */
.blog-filters {
  display: flex; flex-wrap: wrap; gap: var(--space-2);
  margin-bottom: var(--space-10);
}
.blog-filter {
  padding: 0.4rem 1rem;
  border-radius: var(--radius-full);
  font-size: var(--text-sm); font-weight: var(--weight-medium);
  border: 1.5px solid var(--color-border);
  color: var(--color-text-secondary);
  transition: all var(--transition-fast);
}
.blog-filter:hover { border-color: var(--color-brand); color: var(--color-brand); }
.blog-filter--active {
  background: var(--color-brand); color: #fff; border-color: var(--color-brand);
}

/* Featured */
.blog-featured {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: var(--space-8);
  margin-bottom: var(--space-12);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}
.blog-featured__img-link { display: block; }
.blog-featured__img-wrap { position: relative; height: 100%; min-height: 280px; }
.blog-featured__img { width: 100%; height: 100%; object-fit: cover; }

.blog-featured__body {
  padding: var(--space-8);
  display: flex; flex-direction: column; justify-content: center; gap: var(--space-4);
}
.blog-featured__title {
  font-size: clamp(var(--text-xl), 2vw, var(--text-3xl));
  font-weight: var(--weight-extrabold); color: var(--color-dark);
  margin: 0; line-height: var(--line-snug);
}
.blog-featured__title a { color: inherit; }
.blog-featured__title a:hover { color: var(--color-brand); }
.blog-featured__desc {
  color: var(--color-text-secondary); font-size: var(--text-base);
  line-height: var(--line-relaxed); margin: 0;
}
.blog-featured__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }
.blog-featured__tag {
  background: var(--color-primary-50); color: var(--color-brand-dark);
  font-size: var(--text-xs); font-weight: var(--weight-medium);
  padding: 0.2rem 0.6rem; border-radius: var(--radius-full);
}

.blog-grid { margin-top: var(--space-8); }

@media (max-width: 900px) {
  .blog-featured { grid-template-columns: 1fr; }
  .blog-featured__img-wrap { min-height: 220px; }
}
</style>
