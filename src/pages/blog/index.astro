---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

const categories = [
  "Guías",
  "Ahorro",
  "Ecología",
  "Mantenimiento",
  "Comparativas",
  "Proyectos",
  "Técnico",
  "Zonas",
] as const;

const categorySlug = (cat: string) =>
  cat
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase();
---

<BaseLayout
  title="Blog de Calentadores Solares | Guías y Consejos"
  description="Artículos técnicos sobre calentadores solares: guías de compra, consejos de mantenimiento, ahorro en gas y comparativas para elegir el mejor sistema."
  heroTitle="Blog de Calentadores Solares | Guías y Consejos"
  heroIntro="Artículos técnicos sobre instalación, mantenimiento, ahorro y eficiencia de calentadores solares en México. Información práctica para tomar mejores decisiones."
  activePage="blog"
  breadcrumbs={[
    { name: "Inicio", url: "/" },
    { name: "Blog", url: "/blog" },
  ]}
>
  <!-- Filtro por categoría -->
  <section class="section">
    <div class="container">
      <nav class="blog-filters" aria-label="Filtrar artículos por categoría">
        <a href="/blog" class="badge badge--primary blog-filters__link blog-filters__link--active">
          Todos
        </a>
        {categories.map((cat) => (
          <a
            href={`/blog/categoria/${categorySlug(cat)}`}
            class="badge blog-filters__link"
          >
            {cat}
          </a>
        ))}
      </nav>

      <!-- Artículo destacado -->
      {featured && (
        <article class="card blog-featured">
          <a href={`/blog/${featured.slug}`} class="blog-featured__link">
            <div class="blog-featured__img-wrap">
              <img
                src={featured.data.image}
                alt={featured.data.imageAlt}
                class="blog-featured__img"
                loading="eager"
                width="800"
                height="450"
              />
              <span class="badge badge--primary blog-featured__badge">
                {featured.data.category}
              </span>
            </div>
            <div class="card__body blog-featured__body">
              <h2 class="card__title blog-featured__title">
                {featured.data.title}
              </h2>
              <p class="card__desc blog-featured__desc">
                {featured.data.description}
              </p>
              <span class="btn btn--primary">Leer más</span>
            </div>
          </a>
        </article>
      )}

      <!-- Grid de artículos -->
      <div class="grid-3 blog-grid">
        {rest.map((post) => (
          <article class="card blog-card">
            <a href={`/blog/${post.slug}`} class="blog-card__link">
              <div class="blog-card__img-wrap">
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt}
                  class="blog-card__img"
                  loading="lazy"
                  width="400"
                  height="225"
                />
                <span class="badge badge--primary blog-card__badge">
                  {post.data.category}
                </span>
              </div>
              <div class="card__body">
                <h3 class="card__title">{post.data.title}</h3>
                <p class="card__desc">{post.data.description}</p>
                <span class="btn btn--primary blog-card__btn">Leer más</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Filtros de categoría ── */
  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    justify-content: center;
  }

  .blog-filters__link {
    text-decoration: none;
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    font-size: 0.9rem;
    font-weight: 600;
    transition: background 0.2s, color 0.2s;
    border: 2px solid var(--color-primary, #f57c00);
    color: var(--color-primary, #f57c00);
    background: transparent;
  }

  .blog-filters__link:hover,
  .blog-filters__link--active {
    background: var(--color-primary, #f57c00);
    color: #fff;
  }

  /* ── Artículo destacado ── */
  .blog-featured {
    margin-bottom: 3rem;
    overflow: hidden;
  }

  .blog-featured__link {
    display: grid;
    grid-template-columns: 1fr 1fr;
    text-decoration: none;
    color: inherit;
    gap: 0;
  }

  .blog-featured__img-wrap {
    position: relative;
    overflow: hidden;
    min-height: 300px;
  }

  .blog-featured__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .blog-featured__link:hover .blog-featured__img {
    transform: scale(1.03);
  }

  .blog-featured__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
  }

  .blog-featured__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 2.5rem;
  }

  .blog-featured__title {
    font-size: 1.6rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .blog-featured__desc {
    margin-bottom: 1.5rem;
    line-height: 1.6;
    color: var(--color-text-muted, #555);
  }

  /* ── Grid de tarjetas ── */
  .blog-grid {
    gap: 2rem;
  }

  .blog-card {
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .blog-card__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .blog-card__img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .blog-card__link:hover .blog-card__img {
    transform: scale(1.05);
  }

  .blog-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
  }

  .blog-card__btn {
    margin-top: auto;
    align-self: flex-start;
  }

  .card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem;
  }

  .card__title {
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .card__desc {
    color: var(--color-text-muted, #555);
    line-height: 1.55;
    margin-bottom: 1rem;
    flex: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .blog-featured__link {
      grid-template-columns: 1fr;
    }

    .blog-featured__img-wrap {
      min-height: 200px;
      max-height: 280px;
    }

    .blog-featured__body {
      padding: 1.5rem;
    }

    .blog-featured__title {
      font-size: 1.3rem;
    }

    .grid-3.blog-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .grid-3.blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
