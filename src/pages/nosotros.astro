---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import LeadCapture from '../components/LeadCapture.astro';
import { buildOrganizationSchema, buildBreadcrumbSchema } from '../lib/seo';

const structuredData = [
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Nosotros', url: '/nosotros' },
  ]),
];

const hitos = [
  { año: '2008', evento: 'Fundación', desc: 'Comenzamos en CDMX con 3 técnicos y enfoque exclusivo en calentadores solares residenciales.' },
  { año: '2012', evento: 'Expansión comercial', desc: 'Primer proyecto hotelero en Valle de Bravo. Inicio de cartera comercial e industrial.' },
  { año: '2016', evento: '200 instalaciones', desc: 'Alcanzamos 200 sistemas instalados y expandimos cobertura a Estado de México y Morelos.' },
  { año: '2020', evento: 'Tecnología de punta', desc: 'Adoptamos exclusivamente sistemas de tubos evacuados al vacío de alta eficiencia.' },
  { año: '2025', evento: '+500 instalaciones', desc: 'Más de 500 proyectos completados en 7 estados. Equipo de 18 técnicos certificados.' },
];

const valores = [
  { icono: '🎯', titulo: 'Honestidad técnica', desc: 'Nunca vendemos más capacidad de la que necesitas. El dimensionamiento correcto es nuestra primera responsabilidad.' },
  { icono: '🔧', titulo: 'Calidad de instalación', desc: 'El equipo más costoso falla si la instalación es mala. Nuestros técnicos tienen protocolo estricto de instalación y prueba.' },
  { icono: '🤝', titulo: 'Compromiso postventa', desc: 'El trato no termina con la instalación. Atendemos garantías, preguntas y mantenimientos con la misma calidad.' },
  { icono: '🌿', titulo: 'Impacto ambiental', desc: 'Cada instalación es una acción concreta contra el cambio climático. Nos motiva el impacto real, no solo el negocio.' },
];

const equipo = [
  { iniciales: 'RH', nombre: 'Ricardo Herrera', cargo: 'Director General', desc: '20 años en ingeniería térmica solar. Especializó en energía renovable en la UNAM.' },
  { iniciales: 'LP', nombre: 'Laura Peralta', cargo: 'Directora Técnica', desc: 'Ingeniera mecánica. Diseña los protocolos de instalación y calidad del equipo técnico.' },
  { iniciales: 'MV', nombre: 'Miguel Vázquez', cargo: 'Jefe de Proyectos Comerciales', desc: '12 años instalando sistemas industriales y hoteleros en México y Centroamérica.' },
];
---

<BaseLayout
  title="Nosotros | De Calentadores Solares — 15 años instalando en México"
  description="Conoce la historia, equipo y valores de De Calentadores Solares. Más de 500 instalaciones en 7 estados, 15 años de experiencia y garantía real en cada proyecto."
  activePage="nosotros"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Nosotros', url: '/nosotros' }]}
  showHero={true}
  heroTitle="15 Años Instalando Calentadores Solares en México"
  heroIntro="Somos un equipo especializado en energía solar térmica. No vendemos de todo —solo calentadores solares, y los instalamos bien."
  heroBadge="Empresa mexicana"
  heroMetrics={[
    { valor: '+500', texto: 'Instalaciones' },
    { valor: '15+', texto: 'Años de experiencia' },
    { valor: '7', texto: 'Estados con cobertura' },
    { valor: '18', texto: 'Técnicos certificados' },
  ]}
  heroPrimaryText="Contactar equipo"
  heroPrimaryLink="/contacto"
  heroSecondaryText="Ver servicios"
  heroSecondaryLink="/servicios"
>

  <!-- HISTORIA -->
  <section class="section section--alt" aria-labelledby="historia-title">
    <div class="container">
      <SectionHeader
        titulo="Nuestra Historia"
        subtitulo="De un pequeño taller en CDMX a cubrir 7 estados con más de 500 instalaciones"
        idTitulo="historia-title"
        parrafo1="Empezamos en 2008 convencidos de que el calentador solar era la tecnología correcta para México: mucho sol, alto consumo de gas y un país que necesitaba alternativas energéticas accesibles. Lo que no sabíamos era que la mayor parte de nuestro trabajo sería convencer a las personas de que la tecnología funcionaba de verdad."
        parrafo2="15 años después, los resultados hablan solos: más de 500 familias y negocios con agua caliente solar, facturas de gas reducidas en 70-80% y cero instalaciones con falla estructural en nuestra historia. Eso es porque nunca cortamos caminos en la instalación."
      />
      <div class="hitos">
        {hitos.map(h => (
          <div class="hito">
            <div class="hito__año">{h.año}</div>
            <div class="hito__line"><div class="hito__dot"></div></div>
            <div class="hito__body">
              <strong class="hito__evento">{h.evento}</strong>
              <p class="hito__desc">{h.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALORES -->
  <section class="section" aria-labelledby="valores-title">
    <div class="container">
      <SectionHeader
        titulo="Lo que nos define"
        subtitulo="No solo instalamos calentadores — instalamos confianza"
        idTitulo="valores-title"
      />
      <div class="grid-4">
        {valores.map(v => (
          <div class="valor-card">
            <span class="valor-card__icon" aria-hidden="true">{v.icono}</span>
            <h3 class="valor-card__title">{v.titulo}</h3>
            <p class="valor-card__desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ESTADÍSTICAS -->
  <section class="stats-bar" aria-label="Estadísticas de la empresa">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item"><strong class="stat-val">+500</strong><span class="stat-label">Instalaciones realizadas</span></div>
        <div class="stat-item"><strong class="stat-val">80%</strong><span class="stat-label">Ahorro promedio en gas</span></div>
        <div class="stat-item"><strong class="stat-val">15+</strong><span class="stat-label">Años de experiencia</span></div>
        <div class="stat-item"><strong class="stat-val">7</strong><span class="stat-label">Estados con servicio</span></div>
        <div class="stat-item"><strong class="stat-val">18</strong><span class="stat-label">Técnicos certificados</span></div>
        <div class="stat-item"><strong class="stat-val">0</strong><span class="stat-label">Fallas estructurales históricas</span></div>
      </div>
    </div>
  </section>

  <!-- EQUIPO -->
  <section class="section section--alt" aria-labelledby="equipo-title">
    <div class="container">
      <SectionHeader
        titulo="El equipo detrás del proyecto"
        subtitulo="Ingenieros y técnicos especializados en energía solar térmica"
        idTitulo="equipo-title"
      />
      <div class="grid-3 equipo-grid">
        {equipo.map(m => (
          <div class="miembro-card">
            <div class="miembro-card__avatar" aria-hidden="true">{m.iniciales}</div>
            <h3 class="miembro-card__name">{m.nombre}</h3>
            <span class="miembro-card__cargo">{m.cargo}</span>
            <p class="miembro-card__desc">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LeadCapture />

</BaseLayout>

<style>
/* Hitos */
.hitos { display: flex; flex-direction: column; gap: 0; max-width: 760px; margin: 0 auto; }
.hito { display: grid; grid-template-columns: 70px 30px 1fr; gap: var(--space-4); align-items: flex-start; padding-bottom: var(--space-6); }
.hito__año { font-size: var(--text-xl); font-weight: var(--weight-extrabold); color: var(--color-brand); text-align: right; padding-top: 2px; }
.hito__line { display: flex; flex-direction: column; align-items: center; }
.hito__dot { width: 14px; height: 14px; border-radius: 50%; background: var(--color-brand); border: 3px solid var(--color-primary-200); flex-shrink: 0; }
.hito__line::after { content: ''; flex: 1; width: 2px; background: var(--color-border); margin-top: 4px; min-height: 40px; }
.hito:last-child .hito__line::after { display: none; }
.hito__evento { font-weight: var(--weight-bold); color: var(--color-dark); font-size: var(--text-base); }
.hito__desc { font-size: var(--text-sm); color: var(--color-text-secondary); margin: var(--space-1) 0 0; }

/* Valores */
.valor-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-6); text-align: center;
}
.valor-card__icon { font-size: 2.5rem; display: block; margin-bottom: var(--space-3); }
.valor-card__title { font-size: var(--text-lg); font-weight: var(--weight-bold); color: var(--color-dark); margin: 0 0 var(--space-3); }
.valor-card__desc { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin: 0; }

/* Stats bar */
.stats-bar { background: var(--color-dark); padding: var(--space-12) 0; }
.stats-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: var(--space-6); text-align: center; }
.stat-item { display: flex; flex-direction: column; gap: var(--space-2); }
.stat-val { font-size: var(--text-4xl); font-weight: var(--weight-extrabold); color: var(--color-brand); line-height: 1; }
.stat-label { font-size: var(--text-xs); color: rgba(255,255,255,0.65); text-transform: uppercase; letter-spacing: 0.04em; }
@media (max-width: 1024px) { .stats-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 640px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }

/* Equipo */
.miembro-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-8); text-align: center;
}
.miembro-card__avatar {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, var(--color-brand), var(--color-sun-400));
  display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);
  font-size: var(--text-2xl); font-weight: var(--weight-extrabold); color: #fff;
}
.miembro-card__name { font-size: var(--text-xl); font-weight: var(--weight-bold); color: var(--color-dark); margin: 0 0 var(--space-2); }
.miembro-card__cargo { display: block; font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--color-brand); margin-bottom: var(--space-4); }
.miembro-card__desc { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin: 0; }
</style>
