---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildLocalBusinessSchema, buildBreadcrumbSchema } from '../lib/seo';
import { PHONE_DISPLAY, WHATSAPP_NUMBER } from '../lib/config';

const structuredData = [
  buildLocalBusinessSchema(),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Cotizar', url: '/cotizar' },
  ]),
];
---

<BaseLayout
  title="Cotizar Calentador Solar | Respuesta en 24h — De Calentadores Solares"
  description="Solicita cotización de calentador solar en CDMX y México. Residencial, comercial e industrial. Respondemos en menos de 24 horas con precio y propuesta técnica."
  activePage="cotizar"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Cotizar', url: '/cotizar' }]}
  showHero={false}
>

  <div class="cotizar-page">
    <div class="container">
      <div class="cotizar-grid">

        <!-- Formulario principal -->
        <div class="cotizar-main">
          <div class="cotizar-header">
            <span class="badge badge--primary">☀️ Cotización gratuita</span>
            <h1 class="cotizar-title">Cotiza tu Calentador Solar</h1>
            <p class="cotizar-intro">Completa los datos y te enviamos una propuesta personalizada en menos de 24 horas. Sin costo, sin compromiso.</p>
          </div>

          <form class="cotizar-form" id="cotizar-form" novalidate>

            <!-- Paso 1: Tipo de uso -->
            <fieldset class="cotizar-step">
              <legend class="cotizar-step__title">
                <span class="cotizar-step__num">1</span>
                ¿Para qué necesitas el calentador solar?
              </legend>
              <div class="cotizar-options">
                <label class="cotizar-option">
                  <input type="radio" name="tipo_uso" value="Residencial (casa)" required />
                  <span class="cotizar-option__box">
                    <span class="cotizar-option__icon">🏠</span>
                    <strong>Casa habitación</strong>
                    <small>2 a 8 personas</small>
                  </span>
                </label>
                <label class="cotizar-option">
                  <input type="radio" name="tipo_uso" value="Departamento" />
                  <span class="cotizar-option__box">
                    <span class="cotizar-option__icon">🏢</span>
                    <strong>Departamento</strong>
                    <small>1 a 4 personas</small>
                  </span>
                </label>
                <label class="cotizar-option">
                  <input type="radio" name="tipo_uso" value="Hotel o posada" />
                  <span class="cotizar-option__box">
                    <span class="cotizar-option__icon">🏨</span>
                    <strong>Hotel / Posada</strong>
                    <small>Proyecto comercial</small>
                  </span>
                </label>
                <label class="cotizar-option">
                  <input type="radio" name="tipo_uso" value="Gimnasio o spa" />
                  <span class="cotizar-option__box">
                    <span class="cotizar-option__icon">💪</span>
                    <strong>Gimnasio / Spa</strong>
                    <small>Alto consumo</small>
                  </span>
                </label>
                <label class="cotizar-option">
                  <input type="radio" name="tipo_uso" value="Restaurante" />
                  <span class="cotizar-option__box">
                    <span class="cotizar-option__icon">🍽️</span>
                    <strong>Restaurante</strong>
                    <small>Uso intensivo</small>
                  </span>
                </label>
                <label class="cotizar-option">
                  <input type="radio" name="tipo_uso" value="Industrial" />
                  <span class="cotizar-option__box">
                    <span class="cotizar-option__icon">🏭</span>
                    <strong>Industrial</strong>
                    <small>Gran capacidad</small>
                  </span>
                </label>
              </div>
            </fieldset>

            <!-- Paso 2: Capacidad -->
            <fieldset class="cotizar-step">
              <legend class="cotizar-step__title">
                <span class="cotizar-step__num">2</span>
                ¿Cuántas personas usarán el calentador?
              </legend>
              <div class="form-row">
                <div class="form-group">
                  <label for="personas" class="form-label">Número de personas</label>
                  <select id="personas" name="personas" class="form-input" required>
                    <option value="" disabled selected>Selecciona</option>
                    <option value="1-2 personas">1 a 2 personas</option>
                    <option value="3-4 personas">3 a 4 personas</option>
                    <option value="5-6 personas">5 a 6 personas</option>
                    <option value="7-10 personas">7 a 10 personas</option>
                    <option value="Más de 10 personas">Más de 10 personas</option>
                    <option value="No aplica (comercial/industrial)">No aplica (comercial/industrial)</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="zona" class="form-label">Estado / Ciudad</label>
                  <select id="zona" name="zona" class="form-input">
                    <option value="" disabled selected>Selecciona</option>
                    <option>Ciudad de México</option>
                    <option>Estado de México</option>
                    <option>Morelos</option>
                    <option>Puebla</option>
                    <option>Hidalgo</option>
                    <option>Querétaro</option>
                    <option>Tlaxcala</option>
                    <option>Otro estado</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label for="notas" class="form-label">Información adicional (opcional)</label>
                <textarea id="notas" name="notas" class="form-input" rows="3"
                  placeholder="Ej: Tenemos tinaco, casa de 2 pisos, bañera en baño principal, necesito presupuesto urgente..."></textarea>
              </div>
            </fieldset>

            <!-- Paso 3: Contacto -->
            <fieldset class="cotizar-step">
              <legend class="cotizar-step__title">
                <span class="cotizar-step__num">3</span>
                Tus datos de contacto
              </legend>
              <div class="form-row">
                <div class="form-group">
                  <label for="q-nombre" class="form-label">Nombre completo *</label>
                  <input type="text" id="q-nombre" name="nombre" class="form-input" required autocomplete="name" />
                </div>
                <div class="form-group">
                  <label for="q-tel" class="form-label">Teléfono / WhatsApp *</label>
                  <input type="tel" id="q-tel" name="telefono" class="form-input" required autocomplete="tel" />
                </div>
              </div>
              <div class="form-group">
                <label for="q-email" class="form-label">Email (opcional)</label>
                <input type="email" id="q-email" name="email" class="form-input" autocomplete="email"
                  placeholder="Para enviarte la propuesta por correo también" />
              </div>
            </fieldset>

            <button type="submit" class="btn btn--primary btn--lg cotizar-submit">
              ☀️ Enviar cotización por WhatsApp
            </button>
            <p class="cotizar-trust">🔒 Tus datos son confidenciales · Sin compromiso de compra · Respuesta en &lt;24h</p>
          </form>
        </div>

        <!-- Sidebar de confianza -->
        <aside class="cotizar-sidebar">
          <div class="trust-card">
            <h3 class="trust-card__title">¿Por qué cotizar con nosotros?</h3>
            <ul class="trust-list">
              <li><span class="trust-list__icon">⚡</span><div><strong>Respuesta en menos de 24h</strong><p>Te contactamos con propuesta técnica y precio el mismo día o al siguiente.</p></div></li>
              <li><span class="trust-list__icon">🔧</span><div><strong>Instalación ese mismo día</strong><p>Confirmada la cotización, instalamos en 3-5 horas en proyectos residenciales.</p></div></li>
              <li><span class="trust-list__icon">🛡️</span><div><strong>Garantía total</strong><p>Equipo e instalación garantizados. Si algo falla, regresamos sin costo.</p></div></li>
              <li><span class="trust-list__icon">💳</span><div><strong>Financiamiento disponible</strong><p>Hasta 12 meses sin intereses con tarjeta de crédito o esquemas propios.</p></div></li>
              <li><span class="trust-list__icon">📋</span><div><strong>Asesoría gratuita</strong><p>Te calculamos la capacidad exacta para que no compres de más ni de menos.</p></div></li>
            </ul>
          </div>

          <div class="direct-contact">
            <p class="direct-contact__label">¿Prefieres contacto directo?</p>
            <a href={`https://wa.me/${WHATSAPP_NUMBER}?text=Hola%2C%20quiero%20cotizar%20un%20calentador%20solar`}
               class="btn btn--primary" target="_blank" rel="noopener" style="width:100%;justify-content:center;">
              💬 WhatsApp: {PHONE_DISPLAY}
            </a>
            <a href={`tel:+52${PHONE_DISPLAY.replace(/\s/g,'')}`}
               class="btn btn--dark" style="width:100%;justify-content:center;margin-top:var(--space-3);">
              📞 Llamar: {PHONE_DISPLAY}
            </a>
          </div>

          <div class="testimonial-mini">
            <div class="testimonial-card__stars">★★★★★</div>
            <blockquote class="testimonial-mini__text">"Me cotizaron en 2 horas y al día siguiente ya estaba instalado. Ahorro $900 al mes en gas."</blockquote>
            <div class="testimonial-mini__author">— Patricia M., Tlalpan, CDMX</div>
          </div>
        </aside>

      </div>
    </div>
  </div>

</BaseLayout>

<script is:inline>
(function() {
  var form = document.getElementById('cotizar-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var tipo = (form.querySelector('input[name="tipo_uso"]:checked') || {}).value || 'No especificado';
    var personas = document.getElementById('personas').value || '';
    var zona = document.getElementById('zona').value || '';
    var notas = document.getElementById('notas').value.trim();
    var nombre = document.getElementById('q-nombre').value.trim();
    var tel = document.getElementById('q-tel').value.trim();
    var email = document.getElementById('q-email').value.trim();
    if (!nombre || !tel) { alert('Por favor completa nombre y teléfono.'); return; }
    var msg = '☀️ *Solicitud de cotización — De Calentadores Solares*'
      + '\n\n*Tipo de uso:* ' + tipo
      + (personas ? '\n*Personas:* ' + personas : '')
      + (zona ? '\n*Zona:* ' + zona : '')
      + (notas ? '\n*Notas:* ' + notas : '')
      + '\n\n*Nombre:* ' + nombre
      + '\n*Teléfono:* ' + tel
      + (email ? '\n*Email:* ' + email : '');
    window.open('https://wa.me/5215547868402?text=' + encodeURIComponent(msg), '_blank');
  });

  // Visual feedback en opciones de radio
  document.querySelectorAll('.cotizar-option input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
      document.querySelectorAll('.cotizar-option__box').forEach(function(b) { b.classList.remove('selected'); });
      if (radio.checked) radio.closest('.cotizar-option').querySelector('.cotizar-option__box').classList.add('selected');
    });
  });
})();
</script>

<style>
.cotizar-page { padding: var(--space-16) 0 var(--space-2xl); }
.cotizar-grid {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: var(--space-12);
  align-items: start;
}

.cotizar-header { margin-bottom: var(--space-8); }
.cotizar-title {
  font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
  font-weight: var(--weight-extrabold);
  color: var(--color-dark); margin: var(--space-3) 0 var(--space-3);
}
.cotizar-intro { color: var(--color-text-secondary); font-size: var(--text-lg); }

.cotizar-form { display: flex; flex-direction: column; gap: var(--space-8); }
.cotizar-step {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
  margin: 0;
}
.cotizar-step__title {
  display: flex; align-items: center; gap: var(--space-3);
  font-size: var(--text-lg); font-weight: var(--weight-bold);
  color: var(--color-dark); margin-bottom: var(--space-5);
}
.cotizar-step__num {
  width: 32px; height: 32px; border-radius: 50%;
  background: var(--color-brand); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--text-sm); font-weight: var(--weight-bold); flex-shrink: 0;
}

.cotizar-options {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3);
}
.cotizar-option { cursor: pointer; }
.cotizar-option input { position: absolute; opacity: 0; width: 0; height: 0; }
.cotizar-option__box {
  display: flex; flex-direction: column; align-items: center; gap: var(--space-2);
  padding: var(--space-4) var(--space-3); text-align: center;
  border: 2px solid var(--color-border); border-radius: var(--radius-lg);
  cursor: pointer; transition: all var(--transition-base);
}
.cotizar-option__box:hover { border-color: var(--color-brand); background: var(--color-primary-50); }
.cotizar-option__box.selected { border-color: var(--color-brand); background: var(--color-primary-50); }
.cotizar-option input:checked + .cotizar-option__box { border-color: var(--color-brand); background: var(--color-primary-50); }
.cotizar-option__icon { font-size: 2rem; }
.cotizar-option__box strong { font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--color-dark); }
.cotizar-option__box small { font-size: var(--text-xs); color: var(--color-text-muted); }

.cotizar-submit { width: 100%; justify-content: center; font-size: var(--text-lg); padding: 1rem 2rem; }
.cotizar-trust { text-align: center; font-size: var(--text-xs); color: var(--color-text-muted); margin: 0; }

/* Sidebar */
.trust-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
  margin-bottom: var(--space-5);
}
.trust-card__title { font-size: var(--text-lg); font-weight: var(--weight-bold); color: var(--color-dark); margin: 0 0 var(--space-5); }
.trust-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4); }
.trust-list li { display: flex; gap: var(--space-3); align-items: flex-start; }
.trust-list__icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 2px; }
.trust-list li strong { display: block; font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--color-dark); }
.trust-list li p { font-size: var(--text-xs); color: var(--color-text-muted); margin: var(--space-1) 0 0; }

.direct-contact { margin-bottom: var(--space-5); }
.direct-contact__label { font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--color-dark); margin-bottom: var(--space-3); }

.testimonial-mini {
  background: var(--color-primary-50);
  border: 1px solid var(--color-primary-200);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
}
.testimonial-mini__text {
  font-size: var(--text-sm); font-style: italic;
  color: var(--color-text-secondary); margin: var(--space-3) 0;
}
.testimonial-mini__author { font-size: var(--text-xs); font-weight: var(--weight-semibold); color: var(--color-brand); }

@media (max-width: 1024px) {
  .cotizar-grid { grid-template-columns: 1fr; }
  .cotizar-sidebar { order: -1; }
  .trust-card { display: none; }
}
@media (max-width: 640px) {
  .cotizar-options { grid-template-columns: repeat(2, 1fr); }
}
</style>
