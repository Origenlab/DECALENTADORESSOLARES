---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { buildLocalBusinessSchema, buildBreadcrumbSchema } from '../lib/seo';
import { PHONE_DISPLAY, WHATSAPP_NUMBER, EMAIL_PRIMARY, BUSINESS_HOURS } from '../lib/config';

const structuredData = [
  buildLocalBusinessSchema(),
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Contacto', url: '/contacto' },
  ]),
];
---

<BaseLayout
  title="Contacto | De Calentadores Solares — CDMX y México"
  description="Contáctanos para cotizar tu calentador solar. Teléfono, WhatsApp, email y formulario. Respondemos en menos de 24 horas. Instalación en CDMX, Edomex y más."
  activePage="contacto"
  structuredData={structuredData}
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Contacto', url: '/contacto' }]}
  showHero={true}
  heroTitle="Contacto — Estamos para Ayudarte"
  heroIntro="Cotiza tu calentador solar, agenda una visita técnica o resuelve cualquier duda. Respondemos en menos de 24 horas por el canal que prefieras."
  heroBadge="Atención personalizada"
  heroMetrics={[
    { valor: '<24h', texto: 'Tiempo de respuesta' },
    { valor: '7', texto: 'Estados con servicio' },
    { valor: 'Gratis', texto: 'Asesoría técnica' },
  ]}
  heroPrimaryText="WhatsApp directo"
  heroPrimaryLink={`https://wa.me/${WHATSAPP_NUMBER}`}
  heroSecondaryText="Llamar ahora"
  heroSecondaryLink={`tel:+52${PHONE_DISPLAY.replace(/\s/g, '')}`}
>

  <section class="section">
    <div class="container">
      <div class="contacto-grid">
        <!-- Formulario -->
        <div class="contacto-form-wrap">
          <h2 class="contacto-form-title">Envíanos un mensaje</h2>
          <p class="contacto-form-sub">Completa el formulario y te respondemos por WhatsApp o email — lo que prefieras.</p>
          <form class="contacto-form" id="contacto-form" aria-label="Formulario de contacto">
            <div class="form-row">
              <div class="form-group">
                <label for="c-nombre" class="form-label">Nombre completo *</label>
                <input type="text" id="c-nombre" name="nombre" class="form-input" required autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="c-empresa" class="form-label">Empresa (opcional)</label>
                <input type="text" id="c-empresa" name="empresa" class="form-input" autocomplete="organization" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="c-tel" class="form-label">Teléfono *</label>
                <input type="tel" id="c-tel" name="telefono" class="form-input" required autocomplete="tel" />
              </div>
              <div class="form-group">
                <label for="c-email" class="form-label">Email *</label>
                <input type="email" id="c-email" name="email" class="form-input" required autocomplete="email" />
              </div>
            </div>
            <div class="form-group">
              <label for="c-tipo" class="form-label">Tipo de proyecto</label>
              <select id="c-tipo" name="tipo" class="form-input">
                <option value="" disabled selected>Selecciona una opción</option>
                <option value="Residencial">Residencial (casa o departamento)</option>
                <option value="Comercial">Comercial (hotel, gimnasio, restaurante)</option>
                <option value="Industrial">Industrial</option>
                <option value="Mantenimiento">Mantenimiento o reparación</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label for="c-msg" class="form-label">Mensaje *</label>
              <textarea id="c-msg" name="mensaje" class="form-input" rows="4" required placeholder="Cuéntanos qué necesitas..."></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--lg" style="width:100%;justify-content:center;">☀️ Enviar por WhatsApp</button>
          </form>
        </div>

        <!-- Info de contacto -->
        <div class="contacto-info">
          <div class="contacto-info__card">
            <h3>📞 Llámanos</h3>
            <a href="tel:+525547868402" class="contacto-info__value">{PHONE_DISPLAY}</a>
            <p>{BUSINESS_HOURS.fullDisplay}</p>
          </div>
          <div class="contacto-info__card">
            <h3>💬 WhatsApp</h3>
            <a href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" rel="noopener" class="contacto-info__value">{PHONE_DISPLAY}</a>
            <p>Respuesta en menos de 24 horas</p>
          </div>
          <div class="contacto-info__card">
            <h3>📧 Email</h3>
            <a href={`mailto:${EMAIL_PRIMARY}`} class="contacto-info__value">{EMAIL_PRIMARY}</a>
            <p>Para cotizaciones formales y documentación</p>
          </div>
          <div class="contacto-info__card">
            <h3>📍 Cobertura</h3>
            <p class="contacto-info__value">CDMX, Edomex, Morelos, Puebla, Hidalgo, Querétaro y Tlaxcala</p>
            <p>Proyectos especiales en toda la República</p>
          </div>
          <div class="contacto-info__card contacto-info__card--cta">
            <h3>¿Necesitas una cotización rápida?</h3>
            <p>Nuestro formulario de cotización te da respuesta el mismo día.</p>
            <a href="/cotizar" class="btn btn--primary" style="width:100%;justify-content:center;margin-top:var(--space-3);">Ir a Cotizar →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
(function() {
  var form = document.getElementById('contacto-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var n = document.getElementById('c-nombre').value.trim();
    var emp = document.getElementById('c-empresa').value.trim();
    var tel = document.getElementById('c-tel').value.trim();
    var email = document.getElementById('c-email').value.trim();
    var tipo = document.getElementById('c-tipo').value;
    var msg = document.getElementById('c-msg').value.trim();
    var txt = 'Hola, me comunico desde el sitio web.'
      + '\n*Nombre:* ' + n
      + (emp ? '\n*Empresa:* ' + emp : '')
      + '\n*Teléfono:* ' + tel
      + '\n*Email:* ' + email
      + (tipo ? '\n*Tipo de proyecto:* ' + tipo : '')
      + '\n*Mensaje:* ' + msg;
    window.open('https://wa.me/5215547868402?text=' + encodeURIComponent(txt), '_blank');
  });
})();
</script>

<style>
.contacto-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: var(--space-12);
  align-items: start;
}
.contacto-form-wrap {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
}
.contacto-form-title {
  font-size: var(--text-2xl); font-weight: var(--weight-bold);
  color: var(--color-dark); margin: 0 0 var(--space-2);
}
.contacto-form-sub {
  color: var(--color-text-secondary); margin: 0 0 var(--space-6);
}
.contacto-info {
  display: flex; flex-direction: column; gap: var(--space-4);
}
.contacto-info__card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-5) var(--space-6);
}
.contacto-info__card h3 {
  font-size: var(--text-base); font-weight: var(--weight-semibold);
  color: var(--color-dark); margin: 0 0 var(--space-2);
}
.contacto-info__card p {
  font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;
}
.contacto-info__value {
  display: block; font-size: var(--text-lg); font-weight: var(--weight-bold);
  color: var(--color-brand); margin-bottom: var(--space-1);
}
.contacto-info__card--cta {
  background: var(--color-primary-50);
  border-color: var(--color-primary-200);
}
@media (max-width: 900px) {
  .contacto-grid { grid-template-columns: 1fr; }
}
</style>
