---
/**
 * BlogLayout — Layout para artículos de blog con sidebar, TOC, share buttons
 * Usa BaseLayout internamente
 */
import BaseLayout from './BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { buildArticleSchema, buildBreadcrumbSchema } from '../lib/seo';
import { SITE_URL, WHATSAPP_NUMBER } from '../lib/config';

interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  author: string;
  pubDate: Date;
  tags: string[];
  category: string;
  slug: string;
}

const { title, description, image, imageAlt, author, pubDate, tags, category, slug } = Astro.props;

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: title, url: `/blog/${slug}` },
];

const articleSchema = buildArticleSchema({
  title,
  description,
  url: `/blog/${slug}`,
  image,
  authorName: author,
  datePublished: pubDate.toISOString().split('T')[0],
  categoria: category,
});

const breadcrumbSchema = buildBreadcrumbSchema(breadcrumbs);

const allPosts: CollectionEntry<'blog'>[] = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p: CollectionEntry<'blog'>) => !p.data.draft && p.slug !== slug)
  .filter((p: CollectionEntry<'blog'>) => p.data.category === category || p.data.tags.some((t: string) => tags.includes(t)))
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const categories = ['Guías', 'Ahorro', 'Ecología', 'Mantenimiento', 'Comparativas', 'Proyectos', 'Técnico', 'Zonas'];

const shareUrl = `${SITE_URL}/blog/${slug}`;
const shareText = encodeURIComponent(title);
const waShareUrl = `https://wa.me/?text=${encodeURIComponent(`${title} — ${shareUrl}`)}`;
const fbShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
const twShareUrl = `https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(shareUrl)}`;
---

<BaseLayout
  title={`${title} | Blog De Calentadores Solares`}
  description={description}
  ogImage={image}
  ogType="article"
  activePage="blog"
  breadcrumbs={breadcrumbs}
  structuredData={[articleSchema, breadcrumbSchema]}
>
  <!-- Reading progress bar (CSS only) -->
  <div class="reading-progress" aria-hidden="true"></div>

  <div class="container">
    <div class="blog-layout">
      <!-- Main article -->
      <article class="blog-article">
        <header class="blog-article__header">
          <div class="blog-article__meta">
            <span class="badge badge--primary">{category}</span>
            {tags.map(tag => (
              <span class="blog-article__tag">#{tag}</span>
            ))}
          </div>
          <h1 class="blog-article__title">{title}</h1>
          <p class="blog-article__intro">{description}</p>
          <div class="blog-article__author-row">
            <div class="blog-article__avatar">EQ</div>
            <div>
              <span class="blog-article__author-name">{author}</span>
              <span class="blog-article__reading">Lectura de 5-8 min</span>
            </div>
          </div>
        </header>

        {image && (
          <img src={image} alt={imageAlt} class="blog-article__hero-img" loading="eager" />
        )}

        <!-- Table of contents -->
        <nav class="blog-toc" aria-label="Tabla de contenidos">
          <p class="blog-toc__title">En este artículo</p>
          <div class="blog-toc__list" id="toc-list">
            <!-- TOC generated by JS -->
          </div>
        </nav>

        <div class="blog-article__content prose">
          <slot />
        </div>

        <!-- Share buttons -->
        <div class="blog-share">
          <p class="blog-share__title">Comparte este artículo</p>
          <div class="blog-share__buttons">
            <a href={waShareUrl} target="_blank" rel="noopener noreferrer" class="blog-share__btn blog-share__btn--wa" aria-label="Compartir en WhatsApp">
              💬 WhatsApp
            </a>
            <a href={fbShareUrl} target="_blank" rel="noopener noreferrer" class="blog-share__btn blog-share__btn--fb" aria-label="Compartir en Facebook">
              📘 Facebook
            </a>
            <a href={twShareUrl} target="_blank" rel="noopener noreferrer" class="blog-share__btn blog-share__btn--tw" aria-label="Compartir en Twitter">
              🐦 Twitter
            </a>
          </div>
        </div>

        <!-- Tags -->
        <div class="blog-article__tags-footer">
          {tags.map(tag => (
            <span class="badge badge--eco">#{tag}</span>
          ))}
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="blog-sidebar">
        <div class="blog-sidebar__sticky">
          <!-- Author bio -->
          <div class="blog-sidebar__card">
            <div class="blog-sidebar__author">
              <div class="blog-sidebar__avatar">☀️</div>
              <div>
                <p class="blog-sidebar__author-name">Equipo De Calentadores Solares</p>
                <p class="blog-sidebar__author-bio">Especialistas en energía solar térmica con más de 15 años de experiencia en instalación y mantenimiento.</p>
              </div>
            </div>
          </div>

          <!-- CTA -->
          <div class="blog-sidebar__card blog-sidebar__card--cta">
            <p class="blog-sidebar__cta-title">¿Necesitas cotización?</p>
            <p class="blog-sidebar__cta-text">Te asesoramos sin compromiso para elegir el calentador solar ideal.</p>
            <a href="/cotizar" class="btn btn--primary" style="width:100%;justify-content:center;">Cotizar ahora</a>
            <a href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('Hola, leí el artículo: ' + title + '. Me interesa cotizar.')}`} class="btn btn--secondary" style="width:100%;justify-content:center;margin-top:0.5rem;" target="_blank" rel="noopener">💬 WhatsApp</a>
          </div>

          <!-- Categories -->
          <div class="blog-sidebar__card">
            <p class="blog-sidebar__section-title">Categorías</p>
            <div class="blog-sidebar__categories">
              {categories.map(cat => (
                <a href={`/blog?categoria=${encodeURIComponent(cat)}`} class={`blog-sidebar__cat-link ${cat === category ? 'blog-sidebar__cat-link--active' : ''}`}>
                  {cat}
                </a>
              ))}
            </div>
          </div>

          <!-- Related articles -->
          {relatedPosts.length > 0 && (
            <div class="blog-sidebar__card">
              <p class="blog-sidebar__section-title">Artículos relacionados</p>
              <div class="blog-sidebar__related">
                {relatedPosts.map((post: CollectionEntry<'blog'>) => (
                  <a href={`/blog/${post.slug}`} class="blog-sidebar__related-link">
                    <span class="blog-sidebar__related-cat">{post.data.category}</span>
                    <span class="blog-sidebar__related-title">{post.data.title}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>

  <!-- TOC generation script -->
  <script is:inline>
    (function() {
      var content = document.querySelector('.blog-article__content');
      var tocList = document.getElementById('toc-list');
      if (!content || !tocList) return;
      var headings = content.querySelectorAll('h2, h3');
      if (headings.length === 0) { tocList.parentElement.style.display = 'none'; return; }
      var html = '';
      headings.forEach(function(h, i) {
        var id = 'section-' + i;
        h.id = id;
        var indent = h.tagName === 'H3' ? ' blog-toc__item--sub' : '';
        html += '<a href="#' + id + '" class="blog-toc__item' + indent + '">' + h.textContent + '</a>';
      });
      tocList.innerHTML = html;
    })();
  </script>
</BaseLayout>

<style>
  /* Reading progress bar */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(to right, var(--color-brand) var(--scroll, 0%), transparent 0);
    z-index: 9999;
    animation: reading-progress linear;
    animation-timeline: scroll();
  }
  @keyframes reading-progress {
    to { --scroll: 100%; }
  }
  @property --scroll {
    syntax: '<percentage>';
    inherits: false;
    initial-value: 0%;
  }

  /* Blog layout */
  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-10);
    padding-block: var(--space-10);
    align-items: start;
  }

  /* Article */
  .blog-article__header { margin-bottom: var(--space-8); }
  .blog-article__meta { display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; margin-bottom: var(--space-4); }
  .blog-article__tag { font-size: var(--text-xs); color: var(--color-text-muted); }
  .blog-article__title { font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl)); margin-bottom: var(--space-4); line-height: var(--line-tight); }
  .blog-article__intro { font-size: var(--text-lg); color: var(--color-text-secondary); line-height: var(--line-relaxed); margin-bottom: var(--space-6); }
  .blog-article__author-row { display: flex; align-items: center; gap: var(--space-3); }
  .blog-article__avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--color-brand-light); color: var(--color-brand-dark);
    display: flex; align-items: center; justify-content: center;
    font-weight: var(--weight-bold); font-size: var(--text-sm); flex-shrink: 0;
  }
  .blog-article__author-name { font-weight: var(--weight-semibold); color: var(--color-dark); font-size: var(--text-sm); display: block; }
  .blog-article__reading { font-size: var(--text-xs); color: var(--color-text-muted); }
  .blog-article__hero-img { width: 100%; border-radius: var(--radius-xl); margin-bottom: var(--space-8); aspect-ratio: 16/9; object-fit: cover; background: var(--color-bg-alt); }

  /* TOC */
  .blog-toc {
    background: var(--color-bg-alt); border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6); margin-bottom: var(--space-8);
    border-left: 3px solid var(--color-brand);
  }
  .blog-toc__title { font-weight: var(--weight-semibold); color: var(--color-dark); margin-bottom: var(--space-3); font-size: var(--text-sm); }
  .blog-toc__item {
    display: block; padding: var(--space-1) 0; font-size: var(--text-sm);
    color: var(--color-text-secondary); transition: color var(--transition-fast);
  }
  .blog-toc__item:hover { color: var(--color-brand); }
  .blog-toc__item--sub { padding-left: var(--space-4); font-size: var(--text-xs); }

  /* Prose content */
  .prose :global(h2) { margin-top: var(--space-10); margin-bottom: var(--space-4); font-size: var(--text-2xl); }
  .prose :global(h3) { margin-top: var(--space-8); margin-bottom: var(--space-3); font-size: var(--text-xl); }
  .prose :global(p) { margin-bottom: var(--space-4); line-height: var(--line-relaxed); }
  .prose :global(ul), .prose :global(ol) { margin-bottom: var(--space-4); }
  .prose :global(li) { margin-bottom: var(--space-2); line-height: var(--line-relaxed); }
  .prose :global(a) { color: var(--color-brand); text-decoration: underline; }
  .prose :global(a:hover) { color: var(--color-brand-dark); }
  .prose :global(strong) { color: var(--color-dark); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-brand); padding-left: var(--space-4);
    margin: var(--space-6) 0; font-style: italic; color: var(--color-text-secondary);
  }

  /* Share buttons */
  .blog-share { margin-top: var(--space-10); padding-top: var(--space-6); border-top: 1px solid var(--color-border); }
  .blog-share__title { font-weight: var(--weight-semibold); color: var(--color-dark); margin-bottom: var(--space-3); font-size: var(--text-sm); }
  .blog-share__buttons { display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .blog-share__btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-2) var(--space-4); border-radius: var(--radius-full);
    font-size: var(--text-sm); font-weight: var(--weight-medium);
    border: 1px solid var(--color-border); color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }
  .blog-share__btn:hover { border-color: var(--color-brand); color: var(--color-brand); }
  .blog-share__btn--wa:hover { border-color: #25d366; color: #25d366; }
  .blog-share__btn--fb:hover { border-color: #1877f2; color: #1877f2; }
  .blog-share__btn--tw:hover { border-color: #1da1f2; color: #1da1f2; }

  /* Tags footer */
  .blog-article__tags-footer { display: flex; gap: var(--space-2); flex-wrap: wrap; margin-top: var(--space-6); }

  /* Sidebar */
  .blog-sidebar__sticky { position: sticky; top: calc(var(--header-height) + var(--space-6)); display: flex; flex-direction: column; gap: var(--space-5); }
  .blog-sidebar__card {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-xl); padding: var(--space-5);
  }
  .blog-sidebar__card--cta {
    background: linear-gradient(135deg, var(--color-dark-deep), var(--color-dark));
    border-color: transparent;
  }
  .blog-sidebar__author { display: flex; gap: var(--space-3); align-items: flex-start; }
  .blog-sidebar__avatar {
    width: 48px; height: 48px; border-radius: 50%;
    background: linear-gradient(135deg, var(--color-brand), var(--color-sun-400));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
  }
  .blog-sidebar__author-name { font-weight: var(--weight-semibold); color: var(--color-dark); font-size: var(--text-sm); display: block; margin-bottom: var(--space-1); }
  .blog-sidebar__author-bio { font-size: var(--text-xs); color: var(--color-text-muted); line-height: var(--line-relaxed); }
  .blog-sidebar__cta-title { color: #fff; font-weight: var(--weight-bold); font-size: var(--text-lg); margin-bottom: var(--space-2); }
  .blog-sidebar__cta-text { color: rgba(255,255,255,0.75); font-size: var(--text-sm); margin-bottom: var(--space-4); line-height: var(--line-relaxed); }
  .blog-sidebar__section-title { font-weight: var(--weight-semibold); color: var(--color-dark); font-size: var(--text-sm); margin-bottom: var(--space-3); }
  .blog-sidebar__categories { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .blog-sidebar__cat-link {
    font-size: var(--text-xs); padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full); border: 1px solid var(--color-border);
    color: var(--color-text-secondary); transition: all var(--transition-fast);
  }
  .blog-sidebar__cat-link:hover, .blog-sidebar__cat-link--active {
    border-color: var(--color-brand); color: var(--color-brand); background: var(--color-brand-light);
  }
  .blog-sidebar__related { display: flex; flex-direction: column; gap: var(--space-3); }
  .blog-sidebar__related-link {
    display: flex; flex-direction: column; gap: var(--space-1);
    padding: var(--space-3); border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }
  .blog-sidebar__related-link:hover { background: var(--color-bg-alt); }
  .blog-sidebar__related-cat { font-size: var(--text-xs); color: var(--color-brand); font-weight: var(--weight-semibold); text-transform: uppercase; }
  .blog-sidebar__related-title { font-size: var(--text-sm); color: var(--color-dark); font-weight: var(--weight-medium); line-height: var(--line-tight); }

  /* Responsive */
  @media (max-width: 1024px) {
    .blog-layout { grid-template-columns: 1fr; }
    .blog-sidebar__sticky { position: static; }
  }
</style>
