---
interface Props {
  titulo: string;
  descripcion: string;
  enlace: string;
  imagen: string;
  imageAlt: string;
  categoria: string;
  tags?: string[];
  featured?: boolean;
}
const { titulo, descripcion, enlace, imagen, imageAlt, categoria, tags = [], featured = false } = Astro.props;
---
<article class={`blog-card ${featured ? 'blog-card--featured' : ''}`}>
  <a href={enlace} class="blog-card__img-link">
    <div class="blog-card__img-wrap">
      <img src={imagen} alt={imageAlt} class="blog-card__img" loading="lazy" decoding="async" width="480" height="270" />
      <span class="blog-card__cat">{categoria}</span>
    </div>
  </a>
  <div class="blog-card__body">
    <h3 class="blog-card__title"><a href={enlace}>{titulo}</a></h3>
    <p class="blog-card__desc">{descripcion}</p>
    <a href={enlace} class="blog-card__link">Leer artículo →</a>
  </div>
</article>

<style>
.blog-card {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex; flex-direction: column;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
}
.blog-card:hover { box-shadow: var(--shadow-lg); }

.blog-card__img-link { display: block; }
.blog-card__img-wrap { position: relative; aspect-ratio: 16/9; overflow: hidden; }
.blog-card__img { width: 100%; height: 100%; object-fit: cover; }
.blog-card__cat {
  position: absolute; top: var(--space-3); left: var(--space-3);
  background: var(--color-brand); color: #fff;
  font-size: var(--text-xs); font-weight: var(--weight-semibold);
  padding: 0.2rem 0.6rem; border-radius: var(--radius-full);
  text-transform: uppercase; letter-spacing: 0.05em;
}

.blog-card__body {
  padding: var(--space-5) var(--space-6);
  display: flex; flex-direction: column; flex: 1; gap: var(--space-3);
}
.blog-card__title {
  font-size: var(--text-lg); font-weight: var(--weight-bold);
  color: var(--color-dark); margin: 0; line-height: var(--line-snug);
}
.blog-card__title a { color: inherit; }
.blog-card__title a:hover { color: var(--color-brand); }
.blog-card__desc {
  font-size: var(--text-sm); color: var(--color-text-secondary);
  line-height: var(--line-relaxed); margin: 0; flex: 1;
}
.blog-card__link {
  font-size: var(--text-sm); font-weight: var(--weight-semibold);
  color: var(--color-brand); margin-top: auto;
}
.blog-card__link:hover { color: var(--color-brand-dark); }

/* Featured variant */
.blog-card--featured { flex-direction: row; }
.blog-card--featured .blog-card__img-wrap { aspect-ratio: 4/3; min-width: 45%; }
.blog-card--featured .blog-card__title { font-size: var(--text-2xl); }
@media (max-width: 768px) { .blog-card--featured { flex-direction: column; } }
</style>
