---
// LeadCapture — Formulario cotización por WhatsApp (patrón GAMADEMEXICO)
---
<section class="lead-solar" id="cotizar" aria-labelledby="lead-title">
  <div class="container">
    <h2 id="lead-title" class="lead-solar__title">Cotiza tu Calentador Solar Gratis</h2>
    <p class="lead-solar__sub">Te respondemos en menos de 24 horas con la mejor opción para tu hogar o negocio</p>
    <div class="lead-solar__bullets">
      <span class="lead-solar__bullet">Asesoría técnica gratuita</span>
      <span class="lead-solar__bullet">Instalación profesional garantizada</span>
      <span class="lead-solar__bullet">Ahorro de hasta 80% en gas</span>
    </div>
    <form class="lead-solar__form" id="cotizar-form" aria-label="Formulario de cotización">
      <input type="text" class="lead-solar__input" id="lead-nombre" name="nombre"
        placeholder="Tu nombre completo" required aria-label="Nombre completo" autocomplete="name" />
      <input type="tel" class="lead-solar__input" id="lead-tel" name="telefono"
        placeholder="Tu teléfono o WhatsApp" required aria-label="Teléfono" autocomplete="tel" />
      <select class="lead-solar__input" id="lead-tipo" name="tipo_uso" required aria-label="Tipo de uso">
        <option value="" disabled selected>¿Para qué es?</option>
        <option value="Casa habitación">Casa habitación</option>
        <option value="Departamento">Departamento</option>
        <option value="Hotel o posada">Hotel o posada</option>
        <option value="Gimnasio o spa">Gimnasio o spa</option>
        <option value="Restaurante">Restaurante</option>
        <option value="Industria">Uso industrial</option>
        <option value="Otro">Otro</option>
      </select>
      <button type="submit" class="btn btn--primary lead-solar__btn">☀️ Cotizar por WhatsApp</button>
    </form>
    <p class="lead-solar__trust">Sin compromiso · Respuesta en menos de 24h · Asesoría sin costo</p>
    <p class="lead-solar__alt">
      O escríbenos directamente:
      <a href="https://wa.me/5215547868402" target="_blank" rel="noopener">💬 WhatsApp: 55 4786 8402</a>
      · <a href="tel:+525547868402">📞 Llamar</a>
    </p>
  </div>
</section>

<script is:inline>
(function() {
  var form = document.getElementById('cotizar-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var nombre = document.getElementById('lead-nombre').value.trim();
    var tel = document.getElementById('lead-tel').value.trim();
    var tipo = document.getElementById('lead-tipo').value;
    var msg = 'Hola, me interesa cotizar un calentador solar.'
      + '\n*Nombre:* ' + nombre
      + '\n*Teléfono:* ' + tel
      + '\n*Uso:* ' + tipo
      + '\n¿Pueden orientarme?';
    window.open('https://wa.me/5215547868402?text=' + encodeURIComponent(msg), '_blank');
  });
})();
</script>

<style>
.lead-solar {
  padding: var(--space-2xl) 0;
  background: var(--color-dark);
}
.lead-solar .container { max-width: 900px; }
.lead-solar__title {
  font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
  font-weight: var(--weight-extrabold); color: #fff;
  text-align: center; margin: 0 0 var(--space-3);
}
.lead-solar__sub {
  text-align: center; color: rgba(255,255,255,0.75);
  font-size: var(--text-lg); margin: 0 0 var(--space-6);
}
.lead-solar__bullets {
  display: flex; justify-content: center; gap: var(--space-6);
  flex-wrap: wrap; margin-bottom: var(--space-8);
}
.lead-solar__bullet {
  font-size: var(--text-sm); color: rgba(255,255,255,0.8);
}
.lead-solar__bullet::before { content: '✓  '; color: var(--color-brand); font-weight: var(--weight-bold); }
.lead-solar__form {
  display: grid; grid-template-columns: 1fr;
  gap: var(--space-3); margin-bottom: var(--space-5);
}
.lead-solar__input {
  width: 100%; padding: 0.875rem var(--space-4);
  border: 1.5px solid rgba(255,255,255,0.2);
  border-radius: var(--radius-md); font-size: var(--text-base);
  background: rgba(255,255,255,0.08); color: #fff;
  font-family: var(--font-primary);
}
.lead-solar__input::placeholder { color: rgba(255,255,255,0.5); }
.lead-solar__input:focus {
  outline: none; border-color: var(--color-brand);
  background: rgba(255,255,255,0.12);
}
.lead-solar__input option { background: var(--color-dark); color: #fff; }
.lead-solar__btn { width: 100%; justify-content: center; font-size: var(--text-base); }
.lead-solar__trust {
  text-align: center; font-size: var(--text-xs); color: rgba(255,255,255,0.5);
  margin: 0 0 var(--space-3);
}
.lead-solar__alt {
  text-align: center; font-size: var(--text-sm); color: rgba(255,255,255,0.65);
  margin: 0;
}
.lead-solar__alt a { color: var(--color-brand); font-weight: var(--weight-semibold); }
.lead-solar__alt a:hover { color: var(--color-primary-300); }
@media (min-width: 768px) {
  .lead-solar__form { grid-template-columns: 1fr 1fr; }
  .lead-solar__btn { grid-column: 1 / -1; max-width: 320px; margin: 0 auto; }
}
@media (min-width: 1024px) {
  .lead-solar__form { grid-template-columns: 1fr 1fr 1fr auto; }
  .lead-solar__btn { grid-column: auto; max-width: none; margin: 0; }
}
</style>
