---
interface Props {
  titulo: string;
  descripcion: string;
  enlace: string;
  imagen?: string;
  precio?: number;
  precioMin?: number;
  precioMax?: number;
  capacidad?: number;
  tubos?: number;
  usuarios?: string;
  features?: string[];
  featured?: boolean;
}
const { titulo, descripcion, enlace, imagen, precio, precioMin, precioMax, capacidad, tubos, usuarios, features = [], featured = false } = Astro.props;

const precioStr = precio
  ? `$${precio.toLocaleString('es-MX')}`
  : precioMin && precioMax
    ? `$${precioMin.toLocaleString('es-MX')} – $${precioMax.toLocaleString('es-MX')}`
    : null;
---

<article class={`prod-card ${featured ? 'prod-card--featured' : ''}`}>
  {featured && <div class="prod-card__badge">Más vendido</div>}
  <div class="prod-card__img-wrap">
    {imagen
      ? <img src={imagen} alt={titulo} class="prod-card__img" loading="lazy" decoding="async" width="480" height="320" />
      : <div class="prod-card__placeholder"><span aria-hidden="true">☀️</span></div>
    }
  </div>
  <div class="prod-card__body">
    <h3 class="prod-card__title">{titulo}</h3>
    {(capacidad || tubos || usuarios) && (
      <div class="prod-card__specs">
        {capacidad && <span class="prod-card__spec">💧 {capacidad} L</span>}
        {tubos && <span class="prod-card__spec">🔆 {tubos} tubos</span>}
        {usuarios && <span class="prod-card__spec">👥 {usuarios}</span>}
      </div>
    )}
    <p class="prod-card__desc">{descripcion}</p>
    {features.length > 0 && (
      <ul class="prod-card__features">
        {features.slice(0, 3).map(f => <li>{f}</li>)}
      </ul>
    )}
    {precioStr && (
      <div class="prod-card__price">
        <span class="prod-card__price-label">Desde</span>
        <strong class="prod-card__price-val">{precioStr} MXN</strong>
        <span class="prod-card__price-note">+ instalación</span>
      </div>
    )}
    <a href={enlace} class="btn btn--primary prod-card__btn">Ver detalles →</a>
  </div>
</article>

<style>
.prod-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-sm);
  position: relative;
}
.prod-card:hover { box-shadow: var(--shadow-lg); }
.prod-card--featured { border-color: var(--color-brand); border-width: 2px; }

.prod-card__badge {
  position: absolute; top: var(--space-3); right: var(--space-3); z-index: 1;
  background: var(--color-brand); color: #fff;
  font-size: var(--text-xs); font-weight: var(--weight-bold);
  padding: 0.2rem 0.6rem; border-radius: var(--radius-full);
  text-transform: uppercase; letter-spacing: 0.05em;
}

.prod-card__img-wrap { aspect-ratio: 3/2; overflow: hidden; }
.prod-card__img { width: 100%; height: 100%; object-fit: cover; }
.prod-card__placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 4rem;
  background: linear-gradient(135deg, var(--color-primary-50), var(--color-primary-100));
}

.prod-card__body {
  padding: var(--space-5) var(--space-6);
  display: flex; flex-direction: column; flex: 1; gap: var(--space-3);
}
.prod-card__title {
  font-size: var(--text-lg); font-weight: var(--weight-bold);
  color: var(--color-dark); margin: 0; line-height: var(--line-snug);
}
.prod-card__specs {
  display: flex; flex-wrap: wrap; gap: var(--space-2);
}
.prod-card__spec {
  background: var(--color-primary-50); color: var(--color-brand-dark);
  font-size: var(--text-xs); font-weight: var(--weight-semibold);
  padding: 0.2rem 0.6rem; border-radius: var(--radius-full);
}
.prod-card__desc {
  font-size: var(--text-sm); color: var(--color-text-secondary);
  line-height: var(--line-relaxed); margin: 0;
}
.prod-card__features {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: var(--space-1); flex: 1;
}
.prod-card__features li {
  font-size: var(--text-xs); color: var(--color-text-secondary);
  padding-left: 1rem; position: relative;
}
.prod-card__features li::before {
  content: '✓'; position: absolute; left: 0;
  color: var(--color-success); font-weight: var(--weight-bold);
}
.prod-card__price {
  background: var(--color-primary-50);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  margin-top: auto;
}
.prod-card__price-label { font-size: var(--text-xs); color: var(--color-text-muted); display: block; }
.prod-card__price-val { font-size: var(--text-xl); font-weight: var(--weight-extrabold); color: var(--color-brand); }
.prod-card__price-note { font-size: var(--text-xs); color: var(--color-text-muted); margin-left: var(--space-2); }
.prod-card__btn { width: 100%; justify-content: center; border-radius: var(--radius-md); }
</style>
