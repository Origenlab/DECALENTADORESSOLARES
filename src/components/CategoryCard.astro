---
// CategoryCard — tarjeta de categoría de calentador solar
// Patrón: GAMADEMEXICO/src/components/CategoryCard.astro
interface Tipo {
  nombre: string;
  enlace: string;
}
interface Props {
  titulo: string;
  subtitulo: string;
  enlace: string;
  imagen?: string;
  icono?: string;
  tipos?: Tipo[];
}
const { titulo, subtitulo, enlace, imagen, icono = '☀️', tipos = [] } = Astro.props;
---
<article class="cat-card">
  <div class="cat-card__img-wrap">
    {imagen
      ? <img src={imagen} alt={titulo} class="cat-card__img" loading="lazy" decoding="async" width="640" height="360" />
      : <div class="cat-card__placeholder"><span aria-hidden="true">{icono}</span></div>
    }
  </div>
  <div class="cat-card__body">
    <h3 class="cat-card__title">{titulo}</h3>
    <p class="cat-card__sub">{subtitulo}</p>
    {tipos.length > 0 && (
      <div class="cat-card__types">
        {tipos.map(t => (
          <a href={t.enlace} class="cat-card__type-link">{t.nombre}</a>
        ))}
      </div>
    )}
    <a href={enlace} class="btn btn--primary cat-card__btn">Ver {titulo}</a>
  </div>
</article>

<style>
.cat-card {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
}
.cat-card:hover { box-shadow: var(--shadow-lg); }

.cat-card__img-wrap {
  width: 100%; aspect-ratio: 16/9;
  background: var(--color-primary-50);
  overflow: hidden;
}
.cat-card__img { width: 100%; height: 100%; object-fit: cover; }
.cat-card__placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 4rem;
  background: linear-gradient(135deg, var(--color-primary-50), var(--color-primary-100));
}

.cat-card__body {
  padding: var(--space-6);
  display: flex; flex-direction: column; flex: 1; gap: var(--space-3);
}
.cat-card__title {
  font-size: var(--text-xl); font-weight: var(--weight-bold);
  color: var(--color-dark); margin: 0; line-height: var(--line-tight);
}
.cat-card__sub {
  font-size: var(--text-sm); color: var(--color-text-secondary); margin: 0;
}

.cat-card__types {
  display: flex; flex-direction: column; gap: 0; flex: 1; margin-top: var(--space-2);
}
.cat-card__type-link {
  display: block; font-size: var(--text-sm); color: var(--color-text-secondary);
  padding: 0.5rem 0; padding-left: 1rem;
  border-bottom: 1px solid var(--color-border);
  position: relative;
  transition: color var(--transition-fast);
}
.cat-card__type-link::before {
  content: "•"; position: absolute; left: 0;
  color: var(--color-brand); font-weight: var(--weight-bold);
}
.cat-card__type-link:last-child { border-bottom: none; }
.cat-card__type-link:hover { color: var(--color-brand); }

.cat-card__btn {
  margin-top: auto; width: 100%; justify-content: center;
  border-radius: var(--radius-md);
}
</style>
